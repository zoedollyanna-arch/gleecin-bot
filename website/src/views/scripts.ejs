<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head'); %>
    <title>Script Library | GLEECIN Academy</title>
    <link rel="stylesheet" href="/css/scripts.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css">
</head>
<body class="scripts-page">
    <%- include('partials/header'); %>
    
    <main class="scripts-container">
        <div class="scripts-header">
            <h1>Script Library</h1>
            <p>Browse, search, and download community-created scripts for your projects.</p>
        </div>

        <div class="scripts-search-bar">
            <input type="text" id="search-input" placeholder="Search scripts by title, description, or tags..." class="search-input">
            
            <div class="advanced-filters">
                <select id="language-filter" class="filter-select">
                    <option value="all">All Languages</option>
                    <option value="lsl">LSL (Linden Scripting Language)</option>
                    <option value="javascript">JavaScript</option>
                    <option value="python">Python</option>
                </select>
                
                <select id="category-filter" class="filter-select">
                    <option value="all">All Categories</option>
                    <option value="ui">UI Elements</option>
                    <option value="movement">Movement</option>
                    <option value="physics">Physics</option>
                    <option value="animations">Animations</option>
                    <option value="utilities">Utilities</option>
                    <option value="games">Games</option>
                </select>
                
                <button id="apply-filters" class="btn-primary">Apply Filters</button>
            </div>
        </div>

        <div class="tags-container">
            <span class="tag active" data-tag="all">All Tags</span>
            <span class="tag" data-tag="beginner">Beginner</span>
            <span class="tag" data-tag="intermediate">Intermediate</span>
            <span class="tag" data-tag="advanced">Advanced</span>
            <span class="tag" data-tag="free">Free</span>
            <span class="tag" data-tag="premium">Premium</span>
            <span class="tag" data-tag="popular">Popular</span>
        </div>

        <div class="scripts-grid" id="scripts-container">
            <div class="empty-state" id="scripts-loading">
                <p>Loading scripts...</p>
            </div>
        </div>

        <div class="pagination">
            <button class="pagination-btn active">1</button>
            <button class="pagination-btn">2</button>
            <button class="pagination-btn">3</button>
            <button class="pagination-btn">Next →</button>
        </div>
    </main>

    <%- include('partials/footer'); %>
    
    <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
    <script>hljs.highlightAll();</script>
    <script src="/js/scripts.js"></script>
</body>
</html>
