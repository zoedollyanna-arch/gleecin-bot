<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head'); %>
    <title>Support Center | GLEECIN Academy</title>
    <link rel="stylesheet" href="/css/support.css">
</head>
<body class="support-page">
    <%- include('partials/header'); %>
    
    <main class="support-container">
        <div class="support-header">
            <h1>Support Center</h1>
            <p>Find answers to common questions or get help from our team.</p>
        </div>

        <div class="support-search">
            <input type="text" id="support-search" placeholder="Search for help topics..." class="search-input">
            <button id="search-button" class="btn-primary">Search</button>
        </div>

        <div class="support-categories">
            <div class="category">
                <h2>Getting Started</h2>
                <ul>
                    <li><a href="#">How do I enroll in a class?</a></li>
                    <li><a href="#">What are the system requirements?</a></li>
                    <li><a href="#">How do I access the script library?</a></li>
                    <li><a href="#">Where can I find my certificates?</a></li>
                </ul>
            </div>

            <div class="category">
                <h2>Technical Issues</h2>
                <ul>
                    <li><a href="#">My script isn't working</a></li>
                    <li><a href="#">Video lessons won't load</a></li>
                    <li><a href="#">Interactive challenges not responding</a></li>
                    <li><a href="#">Certificate download failed</a></li>
                </ul>
            </div>

            <div class="category">
                <h2>Account & Billing</h2>
                <ul>
                    <li><a href="#">How do I upgrade my subscription?</a></li>
                    <li><a href="#">Cancel my subscription</a></li>
                    <li><a href="#">Update payment method</a></li>
                    <li><a href="#">Request refund</a></li>
                </ul>
            </div>

            <div class="category">
                <h2>Community</h2>
                <ul>
                    <li><a href="#">How do I join the community?</a></li>
                    <li><a href="#">Submit a script to the library</a></li>
                    <li><a href="#">Report inappropriate content</a></li>
                    <li><a href="#">Become a community helper</a></li>
                </ul>
            </div>
        </div>

        <div class="contact-support">
            <h2>Still Need Help?</h2>
            <p>Contact our support team directly for personalized assistance.</p>
            
            <div class="contact-options">
                <div class="contact-option">
                    <i class="fas fa-comment"></i>
                    <h3>Live Chat</h3>
                    <p>Available 24/7</p>
                    <button class="btn-primary">Start Chat</button>
                </div>
                
                <div class="contact-option">
                    <i class="fas fa-envelope"></i>
                    <h3>Email Support</h3>
                    <p>support@gleecin.academy</p>
                    <button class="btn-secondary">Send Email</button>
                </div>
                
                <div class="contact-option">
                    <i class="fas fa-ticket-alt"></i>
                    <h3>Support Ticket</h3>
                    <p>Create a detailed ticket</p>
                    <button class="btn-secondary">Open Ticket</button>
                </div>
            </div>
        </div>
    </main>

    <%- include('partials/footer'); %>
    
    <script src="/js/support.js"></script>
</body>
</html>