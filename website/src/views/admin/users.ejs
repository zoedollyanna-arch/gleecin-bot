<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>User Management - Admin</title>
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    .admin-container {
      background: linear-gradient(135deg, #0F0F14 0%, #1a1a22 100%);
      color: #EAEAEA;
      min-height: 100vh;
      padding: 20px;
    }

    .admin-header {
      background: #1a1a22;
      border-bottom: 2px solid #7B61FF;
      padding: 20px;
      margin-bottom: 30px;
      border-radius: 8px;
    }

    .admin-header h1 {
      color: #7B61FF;
      margin: 0;
      font-size: 2em;
    }

    .admin-nav {
      display: flex;
      gap: 10px;
      margin-top: 15px;
      flex-wrap: wrap;
    }

    .admin-nav a {
      background: #0F0F14;
      color: #00D1FF;
      padding: 10px 15px;
      border-radius: 6px;
      text-decoration: none;
      border: 1px solid #7B61FF;
      transition: all 0.3s;
    }

    .admin-nav a:hover,
    .admin-nav a.active {
      background: #7B61FF;
      color: #0F0F14;
    }

    .content-section {
      background: #1a1a22;
      border: 2px solid #7B61FF;
      border-radius: 8px;
      padding: 25px;
      margin-bottom: 30px;
    }

    .content-section h2 {
      color: #7B61FF;
      margin-top: 0;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .search-bar {
      margin-bottom: 20px;
      display: flex;
      gap: 10px;
    }

    .search-bar input {
      flex: 1;
      padding: 12px;
      background: #0F0F14;
      color: #EAEAEA;
      border: 1px solid #7B61FF;
      border-radius: 6px;
      font-size: 1em;
    }

    .search-bar input::placeholder {
      color: #666;
    }

    .search-bar input:focus {
      outline: none;
      border-color: #00D1FF;
      box-shadow: 0 0 10px rgba(0, 209, 255, 0.3);
    }

    .users-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 15px;
    }

    .users-table th {
      background: #0F0F14;
      color: #00D1FF;
      padding: 12px;
      text-align: left;
      border-bottom: 2px solid #7B61FF;
      font-weight: bold;
    }

    .users-table td {
      padding: 12px;
      border-bottom: 1px solid #333;
      color: #EAEAEA;
    }

    .users-table tr:hover {
      background: rgba(123, 97, 255, 0.1);
    }

    .tier-badge {
      display: inline-block;
      padding: 5px 10px;
      border-radius: 4px;
      font-size: 0.85em;
      font-weight: bold;
    }

    .tier-free {
      background: rgba(170, 170, 170, 0.2);
      color: #AAAAAA;
    }

    .tier-paid {
      background: rgba(123, 97, 255, 0.2);
      color: #7B61FF;
    }

    .tier-advanced {
      background: rgba(0, 209, 255, 0.2);
      color: #00D1FF;
    }

    .admin-badge {
      display: inline-block;
      background: rgba(255, 122, 0, 0.2);
      color: #FF7A00;
      padding: 5px 10px;
      border-radius: 4px;
      font-size: 0.85em;
      font-weight: bold;
    }

    .action-btn {
      background: #7B61FF;
      color: #0F0F14;
      padding: 6px 12px;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-size: 0.85em;
      font-weight: bold;
      margin-right: 5px;
      transition: all 0.3s;
    }

    .action-btn:hover {
      background: #00D1FF;
      color: #0F0F14;
    }

    .empty-state {
      text-align: center;
      padding: 40px;
      color: #999;
    }

    @media (max-width: 768px) {
      .admin-nav {
        flex-direction: column;
      }

      .admin-nav a {
        width: 100%;
        text-align: center;
      }

      .users-table {
        font-size: 0.9em;
      }

      .users-table th,
      .users-table td {
        padding: 8px;
      }

      .action-btn {
        padding: 4px 8px;
        font-size: 0.8em;
      }
    }
  </style>
</head>
<body>
  <div class="admin-container">
    <div class="admin-header">
      <h1>👨‍💼 Admin Dashboard</h1>
      <p style="margin: 10px 0 0 0; color: #999;">Logged in as: <strong><%= user.username %></strong></p>
      <div class="admin-nav">
        <a href="/admin">📊 Dashboard</a>
        <a href="/admin/users" class="active">👥 Users</a>
        <a href="/admin/payments">💰 Payments</a>
        <a href="/admin/scripts">📝 Scripts</a>
        <a href="/admin/lessons">🎓 Lessons</a>
        <a href="/admin/certifications">🏆 Certificates</a>
        <a href="/admin/logs">📋 Logs</a>
        <a href="/auth/logout" style="background: #ff6b6b; color: white; border: 1px solid #ff6b6b;">🚪 Logout</a>
      </div>
    </div>

    <!-- User Management -->
    <div class="content-section">
      <h2>👥 User Management</h2>

      <div class="search-bar">
        <input type="text" id="searchInput" placeholder="Search users by username or email...">
      </div>

      <% if (users && users.length > 0) %>
        <table class="users-table">
          <thead>
            <tr>
              <th>Username</th>
              <th>Email</th>
              <th>Tier</th>
              <th>Role</th>
              <th>Joined</th>
              <th>Last Login</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="usersTableBody">
            <% users.forEach(user => { %>
              <tr class="user-row" data-username="<%= user.username.toLowerCase() %>" data-email="<%= (user.email || '').toLowerCase() %>">
                <td><strong><%= user.username %></strong></td>
                <td><%= user.email || 'N/A' %></td>
                <td>
                  <span class="tier-badge tier-<%= user.tier %>">
                    <%= user.tier.toUpperCase() %>
                  </span>
                </td>
                <td>
                  <% if (user.is_admin) { %>
                    <span class="admin-badge">👑 ADMIN</span>
                  <% } else { %>
                    <span style="color: #999;">Member</span>
                  <% } %>
                </td>
                <td><%= new Date(user.joined_at).toLocaleDateString() %></td>
                <td><%= user.last_login ? new Date(user.last_login).toLocaleDateString() : 'Never' %></td>
                <td>
                  <% if (!user.is_admin) { %>
                    <button class="action-btn" onclick="makeAdmin(<%= user.id %>)">👑 Make Admin</button>
                  <% } %>
                  <button class="action-btn" onclick="changeTier(<%= user.id %>, '<%= user.tier %>')">🎯 Change Tier</button>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      <% } else %>
        <div class="empty-state">
          <p>📭 No users found</p>
        </div>
      <% end %>
    </div>
  </div>

  <script>
    // Search functionality
    document.getElementById('searchInput').addEventListener('keyup', function() {
      const query = this.value.toLowerCase();
      const rows = document.querySelectorAll('.user-row');

      rows.forEach(row => {
        const username = row.dataset.username;
        const email = row.dataset.email;
        
        if (username.includes(query) || email.includes(query)) {
          row.style.display = '';
        } else {
          row.style.display = 'none';
        }
      });
    });

    function makeAdmin(userId) {
      if (confirm('Are you sure you want to promote this user to admin?')) {
        fetch(`/admin/users/${userId}/make-admin`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' }
        })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            alert('✓ User promoted to admin');
            location.reload();
          } else {
            alert('✗ Error: ' + data.error);
          }
        })
        .catch(err => console.error('Error:', err));
      }
    }

    function changeTier(userId, currentTier) {
      const tiers = ['free', 'paid', 'advanced'];
      const newTier = prompt(`Current tier: ${currentTier}\n\nEnter new tier (free, paid, advanced):`);
      
      if (newTier && tiers.includes(newTier)) {
        fetch(`/admin/users/${userId}/set-tier`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ tier: newTier })
        })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            alert('✓ Tier updated');
            location.reload();
          } else {
            alert('✗ Error: ' + data.error);
          }
        })
        .catch(err => console.error('Error:', err));
      } else if (newTier) {
        alert('Invalid tier. Use: free, paid, or advanced');
      }
    }
  </script>
</body>
</html>
