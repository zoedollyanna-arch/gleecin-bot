<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Script Management - Admin</title>
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    .admin-container {
      background: linear-gradient(135deg, #0F0F14 0%, #1a1a22 100%);
      color: #EAEAEA;
      min-height: 100vh;
      padding: 20px;
    }

    .admin-header {
      background: #1a1a22;
      border-bottom: 2px solid #7B61FF;
      padding: 20px;
      margin-bottom: 30px;
      border-radius: 8px;
    }

    .admin-header h1 {
      color: #7B61FF;
      margin: 0;
      font-size: 2em;
    }

    .admin-nav {
      display: flex;
      gap: 10px;
      margin-top: 15px;
      flex-wrap: wrap;
    }

    .admin-nav a {
      background: #0F0F14;
      color: #00D1FF;
      padding: 10px 15px;
      border-radius: 6px;
      text-decoration: none;
      border: 1px solid #7B61FF;
      transition: all 0.3s;
    }

    .admin-nav a:hover,
    .admin-nav a.active {
      background: #7B61FF;
      color: #0F0F14;
    }

    .content-section {
      background: #1a1a22;
      border: 2px solid #7B61FF;
      border-radius: 8px;
      padding: 25px;
      margin-bottom: 30px;
    }

    .content-section h2 {
      color: #7B61FF;
      margin-top: 0;
    }

    .script-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 20px;
      margin-top: 20px;
    }

    .script-card {
      background: #0F0F14;
      border: 2px solid #7B61FF;
      border-radius: 8px;
      padding: 20px;
      transition: all 0.3s;
    }

    .script-card:hover {
      border-color: #00D1FF;
      box-shadow: 0 0 15px rgba(0, 209, 255, 0.3);
    }

    .script-title {
      color: #00D1FF;
      font-size: 1.2em;
      font-weight: bold;
      margin-bottom: 10px;
    }

    .script-category {
      display: inline-block;
      background: rgba(123, 97, 255, 0.2);
      color: #7B61FF;
      padding: 4px 8px;
      border-radius: 4px;
      font-size: 0.85em;
      margin-bottom: 10px;
    }

    .script-author {
      color: #999;
      font-size: 0.9em;
      margin-bottom: 10px;
    }

    .script-description {
      color: #AAAAAA;
      font-size: 0.95em;
      margin-bottom: 15px;
      max-height: 80px;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .script-stats {
      display: flex;
      gap: 15px;
      margin-bottom: 15px;
      font-size: 0.9em;
    }

    .script-stat {
      display: flex;
      align-items: center;
      gap: 5px;
      color: #999;
    }

    .script-stat strong {
      color: #00D1FF;
    }

    .tier-badge {
      display: inline-block;
      padding: 4px 8px;
      border-radius: 4px;
      font-size: 0.8em;
      font-weight: bold;
      margin-right: 5px;
    }

    .tier-free {
      background: rgba(170, 170, 170, 0.2);
      color: #AAAAAA;
    }

    .tier-paid {
      background: rgba(123, 97, 255, 0.2);
      color: #7B61FF;
    }

    .tier-advanced {
      background: rgba(0, 209, 255, 0.2);
      color: #00D1FF;
    }

    .action-btn {
      background: #7B61FF;
      color: #0F0F14;
      padding: 6px 12px;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-size: 0.85em;
      font-weight: bold;
      transition: all 0.3s;
      margin-top: 10px;
      width: 100%;
      text-align: center;
    }

    .action-btn:hover {
      background: #00D1FF;
      color: #0F0F14;
    }

    .action-btn.delete {
      background: #FF4D4D;
      color: white;
      margin-top: 5px;
    }

    .action-btn.delete:hover {
      background: #ff3333;
    }

    .empty-state {
      text-align: center;
      padding: 40px;
      color: #999;
    }

    .upload-section {
      background: #0F0F14;
      border: 2px dashed #7B61FF;
      padding: 30px;
      border-radius: 8px;
      margin-bottom: 30px;
      text-align: center;
    }

    .upload-section h3 {
      color: #7B61FF;
      margin-bottom: 20px;
    }

    @media (max-width: 768px) {
      .admin-nav {
        flex-direction: column;
      }

      .admin-nav a {
        width: 100%;
        text-align: center;
      }

      .script-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <div class="admin-container">
    <div class="admin-header">
      <h1>👨‍💼 Admin Dashboard</h1>
      <p style="margin: 10px 0 0 0; color: #999;">Logged in as: <strong><%= user.username %></strong></p>
      <div class="admin-nav">
        <a href="/admin">📊 Dashboard</a>
        <a href="/admin/users">👥 Users</a>
        <a href="/admin/payments">💰 Payments</a>
        <a href="/admin/scripts" class="active">📝 Scripts</a>
        <a href="/admin/lessons">🎓 Lessons</a>
        <a href="/admin/certifications">🏆 Certificates</a>
        <a href="/admin/logs">📋 Logs</a>
        <a href="/auth/logout" style="background: #ff6b6b; color: white; border: 1px solid #ff6b6b;">🚪 Logout</a>
      </div>
    </div>

    <!-- Upload Section -->
    <div class="content-section">
      <h2>📤 Upload New Script</h2>
      <div class="upload-section">
        <h3>📁 Add Script to Library</h3>
        <form id="uploadForm" enctype="multipart/form-data">
          <input type="text" name="title" placeholder="Script Title" required style="
            width: 100%;
            padding: 10px;
            margin-bottom: 10px;
            background: #1a1a22;
            color: #EAEAEA;
            border: 1px solid #7B61FF;
            border-radius: 6px;
          ">
          <textarea name="description" placeholder="Description" required style="
            width: 100%;
            padding: 10px;
            margin-bottom: 10px;
            background: #1a1a22;
            color: #EAEAEA;
            border: 1px solid #7B61FF;
            border-radius: 6px;
            resize: vertical;
            height: 80px;
          "></textarea>
          <input type="text" name="category" placeholder="Category (e.g., DOM, API, Utilities)" required style="
            width: 100%;
            padding: 10px;
            margin-bottom: 10px;
            background: #1a1a22;
            color: #EAEAEA;
            border: 1px solid #7B61FF;
            border-radius: 6px;
          ">
          <select name="tier" required style="
            width: 100%;
            padding: 10px;
            margin-bottom: 10px;
            background: #1a1a22;
            color: #EAEAEA;
            border: 1px solid #7B61FF;
            border-radius: 6px;
          ">
            <option value="free">Free</option>
            <option value="paid">Paid</option>
            <option value="advanced">Advanced</option>
          </select>
          <input type="file" name="file" accept=".js,.txt,.pdf" required style="margin-bottom: 10px;">
          <button type="submit" class="action-btn" style="width: auto;">📤 Upload Script</button>
        </form>
      </div>
    </div>

    <!-- Script Management -->
    <div class="content-section">
      <h2>📝 Script Management</h2>

      <% if (scripts && scripts.length > 0) %>
        <div class="script-grid">
          <% scripts.forEach(script => { %>
            <div class="script-card">
              <div class="script-title"><%= script.title %></div>
              <div class="script-category"><%= script.category %></div>
              <div class="script-author">By: <strong><%= script.author || 'Admin' %></strong></div>
              <div class="script-description"><%= script.description || 'No description' %></div>
              
              <div class="script-stats">
                <div class="script-stat">
                  <span>📥</span>
                  <strong><%= script.download_count || 0 %></strong> downloads
                </div>
                <div class="script-stat">
                  <span>👁️</span>
                  <strong><%= script.view_count || 0 %></strong> views
                </div>
              </div>

              <div>
                <span class="tier-badge tier-<%= script.price_tier %>">
                  <%= script.price_tier.toUpperCase() %>
                </span>
              </div>

              <button class="action-btn" onclick="editScript(<%= script.id %>)">✏️ Edit</button>
              <button class="action-btn delete" onclick="deleteScript(<%= script.id %>)">🗑️ Delete</button>
            </div>
          <% }); %>
        </div>
      <% } else %>
        <div class="empty-state">
          <p>📭 No scripts in library yet</p>
          <p>Upload your first script to get started!</p>
        </div>
      <% end %>
    </div>
  </div>

  <script>
    document.getElementById('uploadForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(e.target);
      
      fetch('/admin/scripts/upload', {
        method: 'POST',
        body: formData
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          alert('✓ Script uploaded successfully');
          location.reload();
        } else {
          alert('✗ Error: ' + data.error);
        }
      })
      .catch(err => {
        console.error('Error:', err);
        alert('✗ Failed to upload script');
      });
    });

    function editScript(scriptId) {
      alert('Edit feature coming soon!');
    }

    function deleteScript(scriptId) {
      if (confirm('Are you sure you want to delete this script?')) {
        alert('Delete feature coming soon!');
      }
    }
  </script>
</body>
</html>
