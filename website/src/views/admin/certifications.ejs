<%- include('../partials/admin-header', { title: 'Certifications' }) %>

<main class="admin-shell">
  <section class="admin-panel">
    <div class="admin-panel-header">
      <div>
        <p class="admin-eyebrow">Certificates</p>
        <h1>Certifications</h1>
        <p class="admin-muted">Generate, upload, and manage completion certificates for students.</p>
      </div>
    </div>

    <form class="admin-form" action="/admin/certifications" method="post" enctype="multipart/form-data">
      <div class="admin-form-grid">
        <label class="admin-field">
          <span>Student</span>
          <select name="user_id" required>
            <option value="">Select a student</option>
            <% if (Array.isArray(students)) { students.forEach((student) => { %>
              <option value="<%= student.id %>"><%= student.name || student.username || student.email || student.id %></option>
            <% }) } %>
          </select>
        </label>
        <label class="admin-field">
          <span>Certificate title</span>
          <input name="title" type="text" placeholder="Completion certificate">
        </label>
        <label class="admin-field">
          <span>Certificate file</span>
          <input name="certificate_file" type="file" accept=".pdf,image/*">
        </label>
        <label class="admin-field admin-field-full">
          <span>Notes</span>
          <textarea name="notes" rows="4"></textarea>
        </label>
      </div>
      <div class="admin-form-actions">
        <button class="admin-btn admin-btn-primary" type="submit">Upload certificate</button>
      </div>
    </form>
  </section>

  <section class="admin-panel">
    <div class="admin-panel-header">
      <h2>Issued certificates</h2>
    </div>
    <% if (Array.isArray(certifications) && certifications.length) { %>
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Student</th>
              <th>Title</th>
              <th>Status</th>
              <th>Issued</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% certifications.forEach((certification) => { %>
              <tr>
                <td><%= certification.student_name || certification.student || 'Student' %></td>
                <td><%= certification.title || 'Certificate' %></td>
                <td><span class="admin-pill"><%= certification.status || 'Issued' %></span></td>
                <td><%= certification.created_at ? new Date(certification.created_at).toLocaleString() : '—' %></td>
                <td>
                  <div class="admin-row-actions">
                    <% if (certification.file_url) { %><a class="admin-link" href="<%= certification.file_url %>" target="_blank" rel="noreferrer">View</a><% } %>
                    <button class="admin-link-button" type="button" data-cert-regenerate="<%= certification.id %>">Regenerate</button>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p class="admin-empty">No certificates issued yet.</p>
    <% } %>
  </section>
</main>

<%- include('../partials/admin-footer') %>