<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Schedule Management - Admin</title>
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    .admin-container{background:linear-gradient(135deg,#0F0F14 0%,#1a1a22 100%);color:#EAEAEA;min-height:100vh;padding:20px}
    .admin-header{background:#1a1a22;border-bottom:2px solid #7B61FF;padding:20px;margin-bottom:30px;border-radius:8px}
    .admin-nav{display:flex;gap:10px;margin-top:15px;flex-wrap:wrap}
    .admin-nav a{background:#0F0F14;color:#00D1FF;padding:10px 15px;border-radius:6px;text-decoration:none;border:1px solid #7B61FF}
    .admin-nav a:hover,.admin-nav a.active{background:#7B61FF;color:#0F0F14}
    .content-section{background:#1a1a22;border:2px solid #7B61FF;border-radius:8px;padding:25px;margin-bottom:30px}
    .schedule-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:20px;margin-top:20px}
    .schedule-card{background:#0F0F14;border:2px solid #7B61FF;border-radius:8px;padding:20px}
    .announcement-card{background:#0F0F14;border:2px solid #7B61FF;border-radius:8px;padding:20px;margin-bottom:15px}
    .action-btn{background:#7B61FF;color:#0F0F14;padding:8px 12px;border:none;border-radius:4px;cursor:pointer;font-weight:bold;margin-top:10px;width:100%}
    .action-btn:hover{background:#00D1FF}
    .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:15px}
    .form-group{margin-bottom:15px}
    .form-group input,.form-group textarea,.form-group select{width:100%;padding:10px;background:#0F0F14;color:#EAEAEA;border:1px solid #7B61FF;border-radius:6px;font-family:inherit}
    .empty-state{text-align:center;padding:40px;color:#999}
    .badge{display:inline-block;padding:4px 8px;border-radius:4px;font-size:.8em;font-weight:bold}
    .badge.free{background:rgba(170,170,170,.2);color:#AAA}
    .badge.paid{background:rgba(123,97,255,.2);color:#7B61FF}
    .badge.advanced{background:rgba(0,209,255,.2);color:#00D1FF}
    @media (max-width:768px){.admin-nav{flex-direction:column}.admin-nav a{width:100%;text-align:center}.form-grid,.schedule-grid{grid-template-columns:1fr}}
  </style>
</head>
<body>
  <div class="admin-container">
    <div class="admin-header">
      <h1>👨‍💼 Admin Dashboard</h1>
      <p style="margin:10px 0 0 0;color:#999;">Logged in as: <strong><%= user.username %></strong></p>
      <div class="admin-nav">
        <a href="/admin">📊 Dashboard</a><a href="/admin/users">👥 Users</a><a href="/admin/payments">💰 Payments</a><a href="/admin/scripts">📝 Scripts</a><a href="/admin/lessons">🎓 Lessons</a><a href="/admin/session-requests">📅 Sessions</a><a href="/admin/messages">💬 Messages</a><a href="/admin/certifications">🏆 Certificates</a><a href="/admin/logs">📋 Logs</a><a href="/auth/logout" style="background:#ff6b6b;color:white;border:1px solid #ff6b6b;">🚪 Logout</a>
      </div>
    </div>

    <div class="content-section">
      <h2>➕ Create Announcement</h2>
      <form id="createAnnouncementForm">
        <div class="form-grid">
          <div class="form-group"><input type="text" name="title" placeholder="Announcement title" required></div>
          <div class="form-group">
            <select name="important"><option value="false">Normal</option><option value="true">Important</option></select>
          </div>
        </div>
        <div class="form-group"><textarea name="content" placeholder="Announcement content" required></textarea></div>
        <div class="form-group"><input type="datetime-local" name="expires_at"></div>
        <button type="submit" class="action-btn" style="width:auto;">Create Announcement</button>
      </form>
    </div>

    <div class="content-section">
      <h2>Upcoming Classes</h2>
      <% if (classes && classes.length > 0) { %>
        <div class="schedule-grid">
          <% classes.forEach(cls => { %>
            <div class="schedule-card">
              <h3 style="color:#00D1FF;margin-top:0;"><%= cls.name %></h3>
              <p><span class="badge <%= cls.price_tier %>"><%= String(cls.price_tier || 'free').toUpperCase() %></span></p>
              <p><%= cls.instructor || 'TBD' %></p>
              <p style="color:#999;">Start: <%= cls.start_date ? new Date(cls.start_date).toLocaleString() : 'N/A' %></p>
              <p style="color:#999;">End: <%= cls.end_date ? new Date(cls.end_date).toLocaleString() : 'N/A' %></p>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <div class="empty-state">No scheduled classes yet.</div>
      <% } %>
    </div>

    <div class="content-section">
      <h2>Announcements</h2>
      <% if (announcements && announcements.length > 0) { %>
        <% announcements.forEach(announcement => { %>
          <div class="announcement-card">
            <h3 style="color:#00D1FF;margin-top:0;"><%= announcement.title %></h3>
            <p><%= announcement.content || 'No content' %></p>
            <p style="color:#999;">Important: <%= announcement.important ? 'Yes' : 'No' %></p>
          </div>
        <% }); %>
      <% } else { %>
        <div class="empty-state">No announcements yet.</div>
      <% } %>
    </div>
  </div>

  <script>
    document.getElementById('createAnnouncementForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(e.target));
      const res = await fetch('/admin/schedules/announcement', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
      const json = await res.json();
      if (json.success) { alert('Announcement created'); location.reload(); } else { alert(json.error || 'Failed'); }
    });
  </script>
</body>
</html>
