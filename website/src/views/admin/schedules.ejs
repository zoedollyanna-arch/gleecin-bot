<%- include('../partials/admin-header', { title: 'Schedules' }) %>

<main class="admin-shell">
  <section class="admin-panel">
    <div class="admin-panel-header">
      <div>
        <p class="admin-eyebrow">Scheduling</p>
        <h1>Schedules</h1>
        <p class="admin-muted">Create, edit, publish, and delete schedules with live database updates.</p>
      </div>
      <button class="admin-btn admin-btn-primary" type="button" id="toggleScheduleForm">Add New</button>
    </div>

    <form class="admin-form" id="createScheduleForm" hidden>
      <h2>Create schedule</h2>
      <div class="admin-form-grid">
        <label class="admin-field">
          <span>Title</span>
          <input name="title" type="text" required>
        </label>
        <label class="admin-field">
          <span>Instructor</span>
          <input name="instructor" type="text">
        </label>
        <label class="admin-field">
          <span>Date</span>
          <input name="scheduled_date" type="date">
        </label>
        <label class="admin-field">
          <span>Time</span>
          <input name="scheduled_time" type="time">
        </label>
        <label class="admin-field">
          <span>Capacity</span>
          <input name="capacity" type="number" min="1" step="1">
        </label>
        <label class="admin-field">
          <span>Class</span>
          <select name="class_id">
            <option value="">No class attached</option>
            <% if (Array.isArray(classes) && classes.length) { %>
              <% classes.forEach((cls) => { %>
                <option value="<%= cls.id %>"><%= cls.name %></option>
              <% }) %>
            <% } %>
          </select>
        </label>
        <label class="admin-field admin-field-full">
          <span>Description</span>
          <textarea name="description" rows="4"></textarea>
        </label>
      </div>
      <div class="admin-form-actions">
        <button type="submit" class="admin-btn admin-btn-primary">Create schedule</button>
      </div>
    </form>

    <form class="admin-form" id="createAnnouncementForm">
      <h2>New announcement</h2>
      <div class="admin-form-grid">
        <label class="admin-field">
          <span>Title</span>
          <input name="title" type="text" required>
        </label>
        <label class="admin-field admin-field-full">
          <span>Content</span>
          <textarea name="content" rows="4" required></textarea>
        </label>
        <label class="admin-field">
          <span>Expires at</span>
          <input name="expires_at" type="datetime-local">
        </label>
        <label class="admin-field">
          <span>Important</span>
          <select name="important">
            <option value="false">No</option>
            <option value="true">Yes</option>
          </select>
        </label>
      </div>
      <div class="admin-form-actions">
        <button type="submit" class="admin-btn admin-btn-primary">Publish announcement</button>
      </div>
    </form>
  </section>

  <section class="admin-panel">
    <div class="admin-panel-header">
      <h2>Scheduled sessions</h2>
    </div>

    <% if (Array.isArray(schedules) && schedules.length) { %>
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Title</th>
              <th>Instructor</th>
              <th>Date</th>
              <th>Time</th>
              <th>Capacity</th>
              <th>Class</th>
              <th>Published</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% schedules.forEach((schedule) => { %>
              <tr data-schedule-row data-schedule-id="<%= schedule.id %>">
                <td><strong><%= schedule.title || '' %></strong></td>
                <td><%= schedule.instructor || '' %></td>
                <td><%= schedule.scheduled_date ? new Date(schedule.scheduled_date).toLocaleDateString() : '—' %></td>
                <td><%= schedule.scheduled_time || '—' %></td>
                <td><%= schedule.capacity ?? '—' %></td>
                <td><%= schedule.class_name || '—' %></td>
                <td><span class="admin-pill"><%= schedule.published ? 'Published' : 'Draft' %></span></td>
                <td>
                  <div class="admin-row-actions">
                    <button class="admin-btn admin-btn-primary admin-btn-sm" type="button" data-action="edit">Edit</button>
                    <button class="admin-btn admin-btn-secondary admin-btn-sm" type="button" data-action="publish">Publish</button>
                    <button class="admin-btn admin-btn-danger admin-btn-sm" type="button" data-action="delete">Delete</button>
                  </div>
                </td>
              </tr>
              <tr data-schedule-edit-row hidden>
                <td colspan="8">
                  <form class="admin-form admin-schedule-form" data-schedule-id="<%= schedule.id %>">
                    <div class="admin-form-grid">
                      <label class="admin-field">
                        <span>Title</span>
                        <input class="admin-inline-input" name="title" value="<%= schedule.title || '' %>" required>
                      </label>
                      <label class="admin-field">
                        <span>Instructor</span>
                        <input class="admin-inline-input" name="instructor" value="<%= schedule.instructor || '' %>">
                      </label>
                      <label class="admin-field">
                        <span>Date</span>
                        <input class="admin-inline-input" name="scheduled_date" type="date" value="<%= schedule.scheduled_date ? new Date(schedule.scheduled_date).toISOString().slice(0,10) : '' %>">
                      </label>
                      <label class="admin-field">
                        <span>Time</span>
                        <input class="admin-inline-input" name="scheduled_time" type="time" value="<%= schedule.scheduled_time || '' %>">
                      </label>
                      <label class="admin-field">
                        <span>Capacity</span>
                        <input class="admin-inline-input" name="capacity" type="number" min="1" value="<%= schedule.capacity ?? '' %>">
                      </label>
                      <label class="admin-field">
                        <span>Class</span>
                        <select class="admin-inline-input" name="class_id">
                          <option value="">No class attached</option>
                          <% if (Array.isArray(classes) && classes.length) { %>
                            <% classes.forEach((cls) => { %>
                              <option value="<%= cls.id %>" <%= String(schedule.class_id || '') === String(cls.id) ? 'selected' : '' %>><%= cls.name %></option>
                            <% }) %>
                          <% } %>
                        </select>
                      </label>
                      <label class="admin-field admin-field-full">
                        <span>Description</span>
                        <textarea class="admin-inline-input" name="description" rows="4"><%= schedule.description || '' %></textarea>
                      </label>
                    </div>
                    <div class="admin-form-actions">
                      <button class="admin-btn admin-btn-primary" type="submit">Save schedule</button>
                      <button class="admin-btn admin-btn-secondary" type="button" data-cancel-schedule-edit>Cancel</button>
                    </div>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p class="admin-empty">No schedules configured.</p>
    <% } %>
  </section>

  <section class="admin-panel">
    <div class="admin-panel-header">
      <h2>Announcements</h2>
    </div>
    <% if (Array.isArray(announcements) && announcements.length) { %>
      <div class="admin-list">
        <% announcements.forEach((announcement) => { %>
          <article class="admin-list-item">
            <strong><%= announcement.title %></strong>
            <p class="admin-muted"><%= announcement.content %></p>
            <p class="admin-muted">Important: <%= announcement.important ? 'Yes' : 'No' %></p>
          </article>
        <% }) %>
      </div>
    <% } else { %>
      <p class="admin-empty">No announcements yet.</p>
    <% } %>
  </section>
</main>

<script>
  const toggleScheduleForm = document.getElementById('toggleScheduleForm');
  const createScheduleForm = document.getElementById('createScheduleForm');

  toggleScheduleForm?.addEventListener('click', () => {
    createScheduleForm.hidden = !createScheduleForm.hidden;
  });

  const refreshPage = () => window.location.reload();

  document.getElementById('createScheduleForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(e.target));
    const res = await fetch('/admin/schedules/create', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    });
    const json = await res.json();
    if (json.success) {
      refreshPage();
    } else {
      alert(json.error || 'Failed');
    }
  });

  document.getElementById('createAnnouncementForm')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(e.target));
    const res = await fetch('/admin/schedules/announcement', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    });
    const json = await res.json();
    if (json.success) {
      refreshPage();
    } else {
      alert(json.error || 'Failed');
    }
  });

  document.querySelectorAll('[data-schedule-row]').forEach((row) => {
    const scheduleId = row.dataset.scheduleId;
    const editRow = row.nextElementSibling;
    const editForm = editRow?.querySelector('.admin-schedule-form');

    row.querySelector('[data-action="edit"]')?.addEventListener('click', () => {
      if (editRow) editRow.hidden = !editRow.hidden;
    });

    editForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(editForm));
      const res = await fetch(`/admin/schedules/${scheduleId}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      const json = await res.json();
      if (json.success) {
        refreshPage();
      } else {
        alert(json.error || 'Failed to update schedule');
      }
    });

    editForm?.querySelector('[data-cancel-schedule-edit]')?.addEventListener('click', () => {
      if (editRow) editRow.hidden = true;
    });

    row.querySelector('[data-action="publish"]')?.addEventListener('click', async () => {
      const res = await fetch(`/admin/schedules/${scheduleId}/publish`, { method: 'POST' });
      const json = await res.json();
      if (json.success) {
        refreshPage();
      } else {
        alert(json.error || 'Failed to publish schedule');
      }
    });

    row.querySelector('[data-action="delete"]')?.addEventListener('click', async () => {
      if (!confirm('Delete this schedule?')) return;
      const res = await fetch(`/admin/schedules/${scheduleId}/delete`, { method: 'POST' });
      const json = await res.json();
      if (json.success) {
        refreshPage();
      } else {
        alert(json.error || 'Failed to delete schedule');
      }
    });
  });
</script>

<%- include('../partials/admin-footer') %>
