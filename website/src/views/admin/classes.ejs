<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Class Management - Admin</title>
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    .admin-container {
      background: linear-gradient(135deg, #0F0F14 0%, #1a1a22 100%);
      color: #EAEAEA;
      min-height: 100vh;
      padding: 20px;
    }
    .admin-header {
      background: #1a1a22;
      border-bottom: 2px solid #7B61FF;
      padding: 20px;
      margin-bottom: 30px;
      border-radius: 8px;
    }
    .admin-nav { display: flex; gap: 10px; margin-top: 15px; flex-wrap: wrap; }
    .admin-nav a { background: #0F0F14; color: #00D1FF; padding: 10px 15px; border-radius: 6px; text-decoration: none; border: 1px solid #7B61FF; }
    .admin-nav a:hover, .admin-nav a.active { background: #7B61FF; color: #0F0F14; }
    .content-section { background: #1a1a22; border: 2px solid #7B61FF; border-radius: 8px; padding: 25px; margin-bottom: 30px; }
    .content-section h2 { color: #7B61FF; margin-top: 0; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
    .form-group { margin-bottom: 15px; }
    .form-group input, .form-group textarea, .form-group select { width: 100%; padding: 10px; background: #0F0F14; color: #EAEAEA; border: 1px solid #7B61FF; border-radius: 6px; font-family: inherit; }
    .class-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; margin-top: 20px; }
    .class-card { background: #0F0F14; border: 2px solid #7B61FF; border-radius: 8px; padding: 20px; }
    .class-title { color: #00D1FF; font-size: 1.2em; font-weight: bold; margin-bottom: 10px; }
    .class-meta { display: flex; gap: 10px; flex-wrap: wrap; margin: 10px 0; }
    .badge { display: inline-block; padding: 4px 8px; border-radius: 4px; font-size: 0.8em; font-weight: bold; }
    .badge.free { background: rgba(170,170,170,.2); color: #AAAAAA; }
    .badge.paid { background: rgba(123,97,255,.2); color: #7B61FF; }
    .badge.advanced { background: rgba(0,209,255,.2); color: #00D1FF; }
    .action-btn { background: #7B61FF; color: #0F0F14; padding: 8px 12px; border: none; border-radius: 4px; cursor: pointer; font-weight: bold; margin-top: 10px; width: 100%; }
    .action-btn:hover { background: #00D1FF; }
    .empty-state { text-align: center; padding: 40px; color: #999; }
    @media (max-width: 768px) {
      .admin-nav { flex-direction: column; }
      .admin-nav a { width: 100%; text-align: center; }
      .form-grid { grid-template-columns: 1fr; }
      .class-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="admin-container">
    <div class="admin-header">
      <h1>👨‍💼 Admin Dashboard</h1>
      <p style="margin: 10px 0 0 0; color: #999;">Logged in as: <strong><%= user.username %></strong></p>
      <div class="admin-nav">
        <a href="/admin">📊 Dashboard</a>
        <a href="/admin/users">👥 Users</a>
        <a href="/admin/payments">💰 Payments</a>
        <a href="/admin/scripts">📝 Scripts</a>
        <a href="/admin/lessons">🎓 Lessons</a>
        <a href="/admin/session-requests">📅 Sessions</a>
        <a href="/admin/messages">💬 Messages</a>
        <a href="/admin/certifications">🏆 Certificates</a>
        <a href="/admin/logs">📋 Logs</a>
        <a href="/auth/logout" style="background: #ff6b6b; color: white; border: 1px solid #ff6b6b;">🚪 Logout</a>
      </div>
    </div>

    <div class="content-section">
      <h2>➕ Create Class</h2>
      <form id="createClassForm">
        <div class="form-grid">
          <div class="form-group"><input type="text" name="name" placeholder="Class name" required></div>
          <div class="form-group">
            <select name="level" required>
              <option value="">Select level</option>
              <option value="beginner">Beginner</option>
              <option value="intermediate">Intermediate</option>
              <option value="advanced">Advanced</option>
            </select>
          </div>
        </div>
        <div class="form-group"><textarea name="description" placeholder="Class description" required></textarea></div>
        <div class="form-grid">
          <div class="form-group"><input type="text" name="duration" placeholder="Duration"></div>
          <div class="form-group"><input type="text" name="instructor" placeholder="Instructor"></div>
        </div>
        <div class="form-grid">
          <div class="form-group">
            <select name="price_tier" required>
              <option value="free">Free</option>
              <option value="paid">Paid</option>
              <option value="advanced">Advanced</option>
            </select>
          </div>
          <div class="form-group"><input type="number" name="max_students" placeholder="Max students"></div>
        </div>
        <div class="form-grid">
          <div class="form-group"><input type="datetime-local" name="start_date"></div>
          <div class="form-group"><input type="datetime-local" name="end_date"></div>
        </div>
        <div class="form-group"><input type="text" name="topics" placeholder="Topics, comma separated"></div>
        <div class="form-group"><input type="text" name="requirements" placeholder="Requirements, comma separated"></div>
        <button type="submit" class="action-btn" style="width: auto;">Create Class</button>
      </form>
    </div>

    <div class="content-section">
      <h2>Class Management</h2>
      <% if (classes && classes.length > 0) { %>
        <div class="class-grid">
          <% classes.forEach(cls => { %>
            <div class="class-card">
              <div class="class-title"><%= cls.name %></div>
              <div class="class-meta">
                <span class="badge <%= cls.price_tier %>"><%= String(cls.price_tier || 'free').toUpperCase() %></span>
                <span class="badge"><%= cls.level || 'N/A' %></span>
                <span class="badge"><%= cls.instructor || 'TBD' %></span>
              </div>
              <p><%= cls.description || 'No description' %></p>
              <p style="color:#999;">Duration: <%= cls.duration || 'N/A' %></p>
              <button class="action-btn edit-class-btn" data-class-id="<%= cls.id %>">Edit Class</button>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <div class="empty-state">No classes created yet.</div>
      <% } %>
    </div>
  </div>

  <script>
    document.getElementById('createClassForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(e.target));
      const res = await fetch('/admin/classes/create', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
      const json = await res.json();
      if (json.success) { alert('Class created'); location.reload(); } else { alert(json.error || 'Failed'); }
    });

    document.querySelectorAll('.edit-class-btn').forEach((button) => {
      button.addEventListener('click', () => {
        window.location.href = `/class/${button.dataset.classId}`;
      });
    });
  </script>
</body>
</html>
