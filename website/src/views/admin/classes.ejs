<%- include('../partials/admin-header', { title: 'Classes' }) %>

<main class="admin-shell">
  <section class="admin-panel">
    <div class="admin-panel-header">
      <div>
        <p class="admin-eyebrow">Class management</p>
        <h1>Classes</h1>
        <p class="admin-muted">Create classes, update their details, and keep the dashboard theme consistent.</p>
      </div>
    </div>

    <form class="admin-form" id="createClassForm">
      <div class="admin-form-grid">
        <label class="admin-field">
          <span>Class name</span>
          <input type="text" name="name" placeholder="Class name" required>
        </label>
        <label class="admin-field">
          <span>Level</span>
          <select name="level" required>
            <option value="">Select level</option>
            <option value="beginner">Beginner</option>
            <option value="intermediate">Intermediate</option>
            <option value="advanced">Advanced</option>
          </select>
        </label>
        <label class="admin-field admin-field-full">
          <span>Description</span>
          <textarea name="description" rows="4" placeholder="Class description" required></textarea>
        </label>
        <label class="admin-field">
          <span>Duration</span>
          <input type="text" name="duration" placeholder="45 minutes">
        </label>
        <label class="admin-field">
          <span>Instructor</span>
          <input type="text" name="instructor" placeholder="Instructor">
        </label>
        <label class="admin-field">
          <span>Tier</span>
          <select name="price_tier" required>
            <option value="free">Free</option>
            <option value="paid">Paid</option>
            <option value="advanced">Advanced</option>
          </select>
        </label>
        <label class="admin-field">
          <span>Max students</span>
          <input type="number" name="max_students" min="1" placeholder="30">
        </label>
        <label class="admin-field">
          <span>Start date</span>
          <input type="datetime-local" name="start_date">
        </label>
        <label class="admin-field">
          <span>End date</span>
          <input type="datetime-local" name="end_date">
        </label>
        <label class="admin-field admin-field-full">
          <span>Topics</span>
          <input type="text" name="topics" placeholder="Topics, comma separated">
        </label>
        <label class="admin-field admin-field-full">
          <span>Requirements</span>
          <input type="text" name="requirements" placeholder="Requirements, comma separated">
        </label>
      </div>
      <div class="admin-form-actions">
        <button type="submit" class="admin-btn admin-btn-primary">Create class</button>
      </div>
    </form>
  </section>

  <section class="admin-panel">
    <div class="admin-panel-header">
      <h2>Class list</h2>
    </div>

    <% if (Array.isArray(classes) && classes.length > 0) { %>
      <div class="admin-grid admin-grid-3">
        <% classes.forEach((cls) => { %>
          <article class="admin-info-card">
            <h3><%= cls.name %></h3>
            <p class="admin-muted"><%= cls.description || 'No description' %></p>
            <p class="admin-muted">Level: <%= cls.level || 'N/A' %></p>
            <p class="admin-muted">Instructor: <%= cls.instructor || 'TBD' %></p>
            <p class="admin-muted">Tier: <%= String(cls.price_tier || 'free').toUpperCase() %></p>
            <div class="admin-form-actions">
              <button class="admin-btn admin-btn-secondary edit-class-btn" type="button" data-class-id="<%= cls.id %>">Edit</button>
            </div>
          </article>
        <% }) %>
      </div>
    <% } else { %>
      <p class="admin-empty">No classes created yet.</p>
    <% } %>
  </section>
</main>

<script>
  document.getElementById('createClassForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(e.target));
    const res = await fetch('/admin/classes/create', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    });
    const json = await res.json();
    if (json.success) {
      alert('Class created');
      location.reload();
    } else {
      alert(json.error || 'Failed');
    }
  });

  document.querySelectorAll('.edit-class-btn').forEach((button) => {
    button.addEventListener('click', () => {
      window.location.href = `/class/${button.dataset.classId}`;
    });
  });
</script>

<%- include('../partials/admin-footer') %>
