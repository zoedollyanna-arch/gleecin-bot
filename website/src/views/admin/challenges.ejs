<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Challenge Management - Admin</title>
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    .admin-container{background:linear-gradient(135deg,#0F0F14 0%,#1a1a22 100%);color:#EAEAEA;min-height:100vh;padding:20px}
    .admin-header{background:#1a1a22;border-bottom:2px solid #7B61FF;padding:20px;margin-bottom:30px;border-radius:8px}
    .admin-nav{display:flex;gap:10px;margin-top:15px;flex-wrap:wrap}
    .admin-nav a{background:#0F0F14;color:#00D1FF;padding:10px 15px;border-radius:6px;text-decoration:none;border:1px solid #7B61FF}
    .admin-nav a:hover,.admin-nav a.active{background:#7B61FF;color:#0F0F14}
    .content-section{background:#1a1a22;border:2px solid #7B61FF;border-radius:8px;padding:25px;margin-bottom:30px}
    .challenge-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:20px;margin-top:20px}
    .challenge-card{background:#0F0F14;border:2px solid #7B61FF;border-radius:8px;padding:20px}
    .action-btn{background:#7B61FF;color:#0F0F14;padding:8px 12px;border:none;border-radius:4px;cursor:pointer;font-weight:bold;margin-top:10px;width:100%}
    .action-btn:hover{background:#00D1FF}
    .form-grid{display:grid;grid-template-columns:1fr 1fr;gap:15px}
    .form-group{margin-bottom:15px}
    .form-group input,.form-group textarea,.form-group select{width:100%;padding:10px;background:#0F0F14;color:#EAEAEA;border:1px solid #7B61FF;border-radius:6px;font-family:inherit}
    .empty-state{text-align:center;padding:40px;color:#999}
    @media (max-width:768px){.admin-nav{flex-direction:column}.admin-nav a{width:100%;text-align:center}.form-grid,.challenge-grid{grid-template-columns:1fr}}
  </style>
</head>
<body>
  <div class="admin-container">
    <div class="admin-header">
      <h1>👨‍💼 Admin Dashboard</h1>
      <p style="margin:10px 0 0 0;color:#999;">Logged in as: <strong><%= user.username %></strong></p>
      <div class="admin-nav">
        <a href="/admin">📊 Dashboard</a><a href="/admin/users">👥 Users</a><a href="/admin/payments">💰 Payments</a><a href="/admin/scripts">📝 Scripts</a><a href="/admin/classes">🏫 Classes</a><a href="/admin/challenges" class="active">🧩 Challenges</a><a href="/admin/schedules">📆 Schedules</a><a href="/admin/lessons">🎓 Lessons</a><a href="/admin/session-requests">📅 Sessions</a><a href="/admin/messages">💬 Messages</a><a href="/admin/certifications">🏆 Certificates</a><a href="/admin/logs">📋 Logs</a><a href="/auth/logout" style="background:#ff6b6b;color:white;border:1px solid #ff6b6b;">🚪 Logout</a>
      </div>
    </div>

    <div class="content-section">
      <h2>➕ Create Challenge</h2>
      <form id="createChallengeForm">
        <div class="form-grid">
          <div class="form-group"><input type="text" name="title" placeholder="Challenge title" required></div>
          <div class="form-group">
            <select name="difficulty" required><option value="easy">Easy</option><option value="medium">Medium</option><option value="hard">Hard</option></select>
          </div>
        </div>
        <div class="form-group"><textarea name="description" placeholder="Challenge description" required></textarea></div>
        <div class="form-group"><textarea name="starter_code" placeholder="Starter code"></textarea></div>
        <div class="form-grid">
          <div class="form-group"><input type="text" name="level" placeholder="Level" value="beginner"></div>
          <div class="form-group"><select name="price_tier"><option value="free">Free</option><option value="paid">Paid</option><option value="advanced">Advanced</option></select></div>
        </div>
        <div class="form-group"><textarea name="solution" placeholder="Solution"></textarea></div>
        <div class="form-group"><textarea name="explanation" placeholder="Explanation"></textarea></div>
        <button type="submit" class="action-btn" style="width:auto;">Create Challenge</button>
      </form>
    </div>

    <div class="content-section">
      <h2>Challenge Management</h2>
      <% if (challenges && challenges.length > 0) { %>
        <div class="challenge-grid">
          <% challenges.forEach(challenge => { %>
            <div class="challenge-card">
              <h3 style="color:#00D1FF;margin-top:0;"><%= challenge.title %></h3>
              <p><%= challenge.description || 'No description' %></p>
              <p style="color:#999;">Difficulty: <%= challenge.difficulty || 'N/A' %></p>
              <button class="action-btn edit-challenge-btn" data-challenge-id="<%= challenge.id %>">Edit Challenge</button>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <div class="empty-state">No challenges created yet.</div>
      <% } %>
    </div>
  </div>

  <script>
    document.getElementById('createChallengeForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(e.target));
      const res = await fetch('/admin/challenges/create', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
      const json = await res.json();
      if (json.success) { alert('Challenge created'); location.reload(); } else { alert(json.error || 'Failed'); }
    });
    document.querySelectorAll('.edit-challenge-btn').forEach((button) => button.addEventListener('click', () => window.location.href = `/learning?challenge=${button.dataset.challengeId}`));
  </script>
</body>
</html>
