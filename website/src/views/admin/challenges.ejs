<%- include('../partials/admin-header', { title: 'Challenges' }) %>

<main class="admin-shell">
  <section class="admin-panel">
    <div class="admin-panel-header">
      <div>
        <p class="admin-eyebrow">Challenge management</p>
        <h1>Challenges</h1>
        <p class="admin-muted">Review submissions, track completions, and create new coding challenges.</p>
      </div>
    </div>

    <form class="admin-form" id="createChallengeForm">
      <div class="admin-form-grid">
        <label class="admin-field">
          <span>Title</span>
          <input name="title" type="text" placeholder="Challenge title" required>
        </label>
        <label class="admin-field">
          <span>Difficulty</span>
          <select name="difficulty" required>
            <option value="">Select difficulty</option>
            <option value="easy">Easy</option>
            <option value="medium">Medium</option>
            <option value="hard">Hard</option>
          </select>
        </label>
        <label class="admin-field">
          <span>Level</span>
          <select name="level" required>
            <option value="">Select level</option>
            <option value="beginner">Beginner</option>
            <option value="intermediate">Intermediate</option>
            <option value="advanced">Advanced</option>
          </select>
        </label>
        <label class="admin-field">
          <span>Tier</span>
          <select name="price_tier" required>
            <option value="free">Free</option>
            <option value="paid">Paid</option>
            <option value="advanced">Advanced</option>
          </select>
        </label>
        <label class="admin-field admin-field-full">
          <span>Description</span>
          <textarea name="description" rows="4" placeholder="Challenge description" required></textarea>
        </label>
        <label class="admin-field admin-field-full">
          <span>Starter code</span>
          <textarea name="starter_code" rows="6" placeholder="Starter code"></textarea>
        </label>
        <label class="admin-field admin-field-full">
          <span>Solution</span>
          <textarea name="solution" rows="6" placeholder="Solution code"></textarea>
        </label>
        <label class="admin-field admin-field-full">
          <span>Explanation</span>
          <textarea name="explanation" rows="4" placeholder="Explain the approach"></textarea>
        </label>
      </div>
      <div class="admin-form-actions">
        <button class="admin-btn admin-btn-primary" type="submit">Create challenge</button>
      </div>
    </form>
  </section>

  <section class="admin-panel">
    <div class="admin-panel-header">
      <h2>Challenges</h2>
      <p class="admin-muted">Edit, update, and delete challenge content from this dashboard.</p>
    </div>
    <% if (Array.isArray(challenges) && challenges.length) { %>
      <div class="admin-grid admin-grid-2">
        <% challenges.forEach((challenge) => { %>
          <article class="admin-info-card" data-challenge-card data-challenge-id="<%= challenge.id %>">
            <h3><%= challenge.title %></h3>
            <p class="admin-muted"><%= challenge.difficulty || '—' %> · <%= challenge.level || 'beginner' %></p>
            <p class="admin-muted"><%= challenge.description || 'No description' %></p>
            <p class="admin-muted">Submissions: <%= challenge.submission_count ?? 0 %> · Completions: <%= challenge.completion_count ?? 0 %></p>
            <p class="admin-muted">Starter code: <%= challenge.starter_code || 'Not set.' %></p>
            <p class="admin-muted">Solution: <%= challenge.solution || 'Not set.' %></p>
            <p class="admin-muted">Explanation: <%= challenge.explanation || 'Not set.' %></p>
            <span class="admin-pill"><%= String(challenge.price_tier || 'free').toUpperCase() %></span>
            <form class="admin-form admin-challenge-edit-form" data-challenge-id="<%= challenge.id %>">
              <div class="admin-form-grid">
                <label class="admin-field"><span>Title</span><input name="title" type="text" value="<%= challenge.title %>" required></label>
                <label class="admin-field"><span>Difficulty</span>
                  <select name="difficulty">
                    <option value="easy" <%= challenge.difficulty === 'easy' ? 'selected' : '' %>>Easy</option>
                    <option value="medium" <%= challenge.difficulty === 'medium' ? 'selected' : '' %>>Medium</option>
                    <option value="hard" <%= challenge.difficulty === 'hard' ? 'selected' : '' %>>Hard</option>
                  </select>
                </label>
                <label class="admin-field"><span>Level</span>
                  <select name="level">
                    <option value="beginner" <%= (challenge.level || 'beginner') === 'beginner' ? 'selected' : '' %>>Beginner</option>
                    <option value="intermediate" <%= challenge.level === 'intermediate' ? 'selected' : '' %>>Intermediate</option>
                    <option value="advanced" <%= challenge.level === 'advanced' ? 'selected' : '' %>>Advanced</option>
                  </select>
                </label>
                <label class="admin-field"><span>Tier</span>
                  <select name="price_tier">
                    <option value="free" <%= (challenge.price_tier || 'free') === 'free' ? 'selected' : '' %>>Free</option>
                    <option value="paid" <%= challenge.price_tier === 'paid' ? 'selected' : '' %>>Paid</option>
                    <option value="advanced" <%= challenge.price_tier === 'advanced' ? 'selected' : '' %>>Advanced</option>
                  </select>
                </label>
                <label class="admin-field admin-field-full"><span>Description</span><textarea name="description" rows="4"><%= challenge.description || '' %></textarea></label>
                <label class="admin-field admin-field-full"><span>Starter code</span><textarea name="starter_code" rows="6"><%= challenge.starter_code || '' %></textarea></label>
                <label class="admin-field admin-field-full"><span>Solution</span><textarea name="solution" rows="6"><%= challenge.solution || '' %></textarea></label>
                <label class="admin-field admin-field-full"><span>Explanation</span><textarea name="explanation" rows="4"><%= challenge.explanation || '' %></textarea></label>
              </div>
              <div class="admin-form-actions">
                <button class="admin-btn admin-btn-primary" type="submit">Update challenge</button>
                <button class="admin-btn admin-btn-secondary" type="button" data-delete-challenge="<%= challenge.id %>">Delete</button>
              </div>
            </form>
          </article>
        <% }) %>
      </div>
    <% } else { %>
      <p class="admin-empty">No challenges created yet.</p>
    <% } %>
  </section>

  <section class="admin-panel">
    <div class="admin-panel-header">
      <h2>Recent submissions</h2>
    </div>
    <% if (Array.isArray(submissions) && submissions.length) { %>
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Student</th>
              <th>Challenge</th>
              <th>Status</th>
              <th>Submitted</th>
            </tr>
          </thead>
          <tbody>
            <% submissions.forEach((submission) => { %>
              <tr>
                <td><%= submission.student_name || 'Student' %></td>
                <td><%= submission.challenge_title || 'Challenge' %></td>
                <td><span class="admin-pill"><%= submission.status || 'submitted' %></span></td>
                <td><%= submission.submitted_at ? new Date(submission.submitted_at).toLocaleString() : '—' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p class="admin-empty">No submissions available.</p>
    <% } %>
  </section>
</main>

<script>
  const createChallengeForm = document.getElementById('createChallengeForm');
  if (createChallengeForm) {
    createChallengeForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(e.target));
      const res = await fetch('/admin/challenges/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      const json = await res.json();
      if (json.success) {
        alert('Challenge created');
        location.reload();
      } else {
        alert(json.error || 'Failed');
      }
    });
  }

  document.querySelectorAll('.admin-challenge-edit-form').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const challengeId = form.dataset.challengeId;
      const data = Object.fromEntries(new FormData(form));
      const res = await fetch(`/admin/challenges/${challengeId}/update`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      const json = await res.json();
      if (json.success) {
        alert('Challenge updated');
        location.reload();
      } else {
        alert(json.error || 'Failed to update challenge');
      }
    });
  });

  document.querySelectorAll('[data-delete-challenge]').forEach((button) => {
    button.addEventListener('click', async () => {
      const challengeId = button.dataset.deleteChallenge;
      if (!confirm('Delete this challenge permanently?')) return;
      const res = await fetch(`/admin/challenges/${challengeId}/delete`, { method: 'POST' });
      const json = await res.json();
      if (json.success) {
        alert('Challenge deleted');
        location.reload();
      } else {
        alert(json.error || 'Failed to delete challenge');
      }
    });
  });
</script>

<%- include('../partials/admin-footer') %>
