<%- include('../partials/admin-header', { title: 'Challenges' }) %>

<main class="admin-shell">
  <section class="admin-panel">
    <div class="admin-panel-header">
      <div>
        <p class="admin-eyebrow">Challenge management</p>
        <h1>Challenges</h1>
        <p class="admin-muted">Review submissions, completion status, and student performance without leaving the admin area.</p>
      </div>
    </div>

    <% if (Array.isArray(challenges) && challenges.length) { %>
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Challenge</th>
              <th>Lesson</th>
              <th>Submissions</th>
              <th>Completions</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% challenges.forEach((challenge) => { %>
              <tr>
                <td><strong><%= challenge.title %></strong><p class="admin-muted"><%= challenge.slug || '' %></p></td>
                <td><%= challenge.lesson_title || challenge.lesson || '—' %></td>
                <td><%= challenge.submission_count ?? challenge.submissions ?? 0 %></td>
                <td><%= challenge.completion_count ?? challenge.completions ?? 0 %></td>
                <td><a class="admin-link" href="/admin/challenges/<%= challenge.id %>">Review</a></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p class="admin-empty">No challenges created yet.</p>
    <% } %>
  </section>

  <section class="admin-panel">
    <div class="admin-panel-header">
      <h2>Recent submissions</h2>
    </div>
    <% if (Array.isArray(submissions) && submissions.length) { %>
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Student</th>
              <th>Challenge</th>
              <th>Status</th>
              <th>Submitted</th>
            </tr>
          </thead>
          <tbody>
            <% submissions.forEach((submission) => { %>
              <tr>
                <td><%= submission.student_name || submission.student || 'Student' %></td>
                <td><%= submission.challenge_title || submission.challenge || 'Challenge' %></td>
                <td><span class="admin-pill"><%= submission.status || 'Submitted' %></span></td>
                <td><%= submission.created_at ? new Date(submission.created_at).toLocaleString() : '—' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p class="admin-empty">No submissions available.</p>
    <% } %>
  </section>
</main>

<%- include('../partials/admin-footer') %>