<%- include('../partials/admin-header', { title: 'Messages' }) %>

<main class="admin-shell">
  <section class="admin-panel">
    <div class="admin-panel-header">
      <div>
        <p class="admin-eyebrow">Inbox</p>
        <h1>Messages</h1>
        <p class="admin-muted">Handle incoming student messages with a direct reply workflow.</p>
      </div>
    </div>

    <div class="admin-inbox">
      <aside class="admin-inbox-list">
        <% if (Array.isArray(messages) && messages.length) { %>
          <% messages.forEach((message) => { %>
            <button class="admin-inbox-item <%= selectedMessage && selectedMessage.id === message.id ? 'is-active' : '' %>" type="button" data-message-id="<%= message.id %>">
              <strong><%= message.subject || 'No subject' %></strong>
              <span><%= message.sender_name || message.sender || 'Student' %></span>
              <small><%= message.created_at ? new Date(message.created_at).toLocaleString() : '' %></small>
            </button>
          <% }) %>
        <% } else { %>
          <p class="admin-empty">No messages in the inbox.</p>
        <% } %>
      </aside>

      <section class="admin-inbox-detail">
        <% if (selectedMessage) { %>
          <article class="admin-message-card">
            <h2><%= selectedMessage.subject || 'No subject' %></h2>
            <p class="admin-muted">From <%= selectedMessage.sender_name || selectedMessage.sender || 'Student' %> · <%= selectedMessage.created_at ? new Date(selectedMessage.created_at).toLocaleString() : '' %></p>
            <div class="admin-message-body"><%= selectedMessage.body || selectedMessage.message || '' %></div>
          </article>

          <form class="admin-form" action="/admin/messages/<%= selectedMessage.id %>/reply" method="post">
            <label class="admin-field">
              <span>Reply</span>
              <textarea name="reply" rows="8" placeholder="Write a direct reply..."></textarea>
            </label>
            <div class="admin-form-actions">
              <button class="admin-btn admin-btn-primary" type="submit">Send reply</button>
            </div>
          </form>
        <% } else { %>
          <div class="admin-empty-state">
            <p class="admin-empty">Select a message to review and reply.</p>
          </div>
        <% } %>
      </section>
    </div>
  </section>
</main>

<%- include('../partials/admin-footer') %>