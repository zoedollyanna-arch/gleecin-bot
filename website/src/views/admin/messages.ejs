<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Support Messages - Admin</title>
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    .admin-container {
      background: linear-gradient(135deg, #0F0F14 0%, #1a1a22 100%);
      color: #EAEAEA;
      min-height: 100vh;
      padding: 20px;
    }

    .admin-header {
      background: #1a1a22;
      border-bottom: 2px solid #7B61FF;
      padding: 20px;
      margin-bottom: 30px;
      border-radius: 8px;
    }

    .admin-header h1 {
      color: #7B61FF;
      margin: 0;
      font-size: 2em;
    }

    .admin-nav {
      display: flex;
      gap: 10px;
      margin-top: 15px;
      flex-wrap: wrap;
    }

    .admin-nav a {
      background: #0F0F14;
      color: #00D1FF;
      padding: 10px 15px;
      border-radius: 6px;
      text-decoration: none;
      border: 1px solid #7B61FF;
      transition: all 0.3s;
    }

    .admin-nav a:hover {
      background: #7B61FF;
      color: #0F0F14;
    }

    .messages-grid {
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 20px;
      margin-bottom: 30px;
    }

    .messages-list {
      background: #1a1a22;
      border: 2px solid #7B61FF;
      border-radius: 8px;
      padding: 25px;
      height: 600px;
      overflow-y: auto;
    }

    .messages-list h2 {
      color: #7B61FF;
      margin-top: 0;
    }

    .message-item {
      background: #0F0F14;
      border: 1px solid #7B61FF;
      border-radius: 6px;
      padding: 15px;
      margin-bottom: 10px;
      cursor: pointer;
      transition: all 0.3s;
    }

    .message-item:hover {
      background: rgba(123, 97, 255, 0.2);
    }

    .message-item.unread {
      border-left: 4px solid #FF7A00;
      font-weight: bold;
    }

    .message-item.active {
      border-left: 4px solid #00D1FF;
      background: rgba(123, 97, 255, 0.3);
    }

    .message-from {
      color: #00D1FF;
      font-weight: bold;
      margin-bottom: 3px;
    }

    .message-preview {
      color: #999;
      font-size: 0.9em;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .message-time {
      color: #666;
      font-size: 0.8em;
      margin-top: 5px;
    }

    .message-detail {
      background: #1a1a22;
      border: 2px solid #7B61FF;
      border-radius: 8px;
      padding: 25px;
    }

    .message-detail h3 {
      color: #7B61FF;
      margin-top: 0;
    }

    .message-header {
      background: #0F0F14;
      border: 1px solid #7B61FF;
      border-radius: 6px;
      padding: 15px;
      margin-bottom: 20px;
    }

    .message-header p {
      margin: 5px 0;
      color: #EAEAEA;
    }

    .message-header strong {
      color: #00D1FF;
    }

    .message-content {
      background: #0F0F14;
      border: 1px solid #7B61FF;
      border-radius: 6px;
      padding: 20px;
      margin-bottom: 20px;
      min-height: 150px;
      white-space: pre-wrap;
      word-wrap: break-word;
    }

    .reply-section {
      background: #0F0F14;
      border: 1px solid #7B61FF;
      border-radius: 6px;
      padding: 20px;
    }

    .reply-label {
      color: #7B61FF;
      margin-bottom: 10px;
      font-weight: bold;
    }

    textarea {
      width: 100%;
      min-height: 120px;
      background: #0F0F14;
      border: 1px solid #7B61FF;
      color: #EAEAEA;
      padding: 12px;
      border-radius: 6px;
      font-family: monospace;
      resize: vertical;
    }

    textarea:focus {
      outline: none;
      border-color: #00D1FF;
      box-shadow: 0 0 10px rgba(0, 209, 255, 0.3);
    }

    .btn {
      background: #7B61FF;
      color: white;
      padding: 10px 20px;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-weight: bold;
      margin-top: 10px;
      transition: all 0.3s;
    }

    .btn:hover {
      background: #6a4df5;
    }

    .empty-state {
      text-align: center;
      padding: 40px;
      color: #999;
    }

    .unread-badge {
      background: #FF7A00;
      color: white;
      border-radius: 50%;
      padding: 2px 6px;
      font-size: 0.8em;
      margin-left: 5px;
    }

    @media (max-width: 1024px) {
      .messages-grid {
        grid-template-columns: 1fr;
      }

      .messages-list {
        height: auto;
        max-height: 400px;
      }
    }

    @media (max-width: 768px) {
      .admin-nav {
        flex-direction: column;
      }

      .admin-nav a {
        width: 100%;
        text-align: center;
      }
    }
  </style>
</head>
<body>
  <div class="admin-container">
    <div class="admin-header">
      <h1>💬 Support Messages</h1>
      <p style="margin: 10px 0 0 0; color: #999;">
        Respond to student support requests 
        <% if (unreadCount > 0) { %>
          <span class="unread-badge"><%= unreadCount %> Unread</span>
        <% } %>
      </p>
      <div class="admin-nav">
        <a href="/admin">📊 Dashboard</a>
        <a href="/admin/users">👥 Users</a>
        <a href="/admin/payments">💰 Payments</a>
        <a href="/admin/scripts">📝 Scripts</a>
        <a href="/admin/lessons">🎓 Lessons</a>
        <a href="/admin/session-requests">📅 Sessions</a>
        <a href="/admin/messages" style="background: #7B61FF; color: #0F0F14;">💬 Messages</a>
        <a href="/admin/certifications">🏆 Certificates</a>
        <a href="/admin/logs">📋 Logs</a>
        <a href="/auth/logout" style="background: #ff6b6b; color: white; border: 1px solid #ff6b6b;">🚪 Logout</a>
      </div>
    </div>

    <div class="messages-grid">
      <div class="messages-list">
        <h2>Messages</h2>
        
        <% if (messages && messages.length > 0) %>
          <% messages.forEach((msg, idx) => { %>
            <div 
              class="message-item <%= msg.is_read ? '' : 'unread' %>" 
              onclick="loadMessage(<%= msg.id %>)"
              id="msg-<%= msg.id %>"
            >
              <div class="message-from"><%= msg.sender_name %></div>
              <div class="message-preview"><%= msg.content.substring(0, 50) %>...</div>
              <div class="message-time"><%= new Date(msg.created_at).toLocaleDateString() %></div>
            </div>
          <% }); %>
        <% else %>
          <div class="empty-state">
            <p>📭 No messages</p>
          </div>
        <% end %>
      </div>

      <div class="message-detail" id="message-detail">
        <div style="text-align: center; color: #999; padding: 40px;">
          <p>Select a message to view details</p>
        </div>
      </div>
    </div>
  </div>

  <script>
    let messages = <%- JSON.stringify(messages) %>;

    function loadMessage(messageId) {
      const msg = messages.find(m => m.id === messageId);
      if (!msg) return;

      const html = `
        <div>
          <h3 style="color: #7B61FF; margin-top: 0;">${msg.subject || 'Support Message'}</h3>
          
          <div class="message-header">
            <p><strong>From:</strong> ${msg.sender_name} (${msg.sender_id})</p>
            <p><strong>Date:</strong> ${new Date(msg.created_at).toLocaleString()}</p>
            <p><strong>Status:</strong> ${msg.is_read ? 'Read' : 'Unread'}</p>
          </div>

          <div class="message-content">${msg.content}</div>

          <div class="reply-section">
            <div class="reply-label">Send Reply</div>
            <textarea id="reply-content" placeholder="Type your response here..."></textarea>
            <button class="btn" onclick="sendReply(${messageId})">Send Reply</button>
          </div>
        </div>
      `;

      document.getElementById('message-detail').innerHTML = html;
      
      // Update UI
      document.querySelectorAll('.message-item').forEach(el => el.classList.remove('active'));
      document.getElementById(`msg-${messageId}`).classList.add('active');
    }

    function sendReply(messageId) {
      const content = document.getElementById('reply-content').value;
      if (!content.trim()) {
        alert('Please enter a reply');
        return;
      }

      fetch(`/admin/messages/${messageId}/reply`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ content })
      })
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          alert('Reply sent!');
          location.reload();
        } else {
          alert('Error: ' + data.error);
        }
      })
      .catch(e => alert('Error: ' + e.message));
    }
  </script>
</body>
</html>
