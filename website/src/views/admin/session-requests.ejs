<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Session Requests - Admin</title>
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    .admin-container {
      background: linear-gradient(135deg, #0F0F14 0%, #1a1a22 100%);
      color: #EAEAEA;
      min-height: 100vh;
      padding: 20px;
    }

    .admin-header {
      background: #1a1a22;
      border-bottom: 2px solid #7B61FF;
      padding: 20px;
      margin-bottom: 30px;
      border-radius: 8px;
    }

    .admin-header h1 {
      color: #7B61FF;
      margin: 0;
      font-size: 2em;
    }

    .admin-nav {
      display: flex;
      gap: 10px;
      margin-top: 15px;
      flex-wrap: wrap;
    }

    .admin-nav a {
      background: #0F0F14;
      color: #00D1FF;
      padding: 10px 15px;
      border-radius: 6px;
      text-decoration: none;
      border: 1px solid #7B61FF;
      transition: all 0.3s;
    }

    .admin-nav a:hover {
      background: #7B61FF;
      color: #0F0F14;
    }

    .requests-section {
      background: #1a1a22;
      border: 2px solid #7B61FF;
      border-radius: 8px;
      padding: 25px;
      margin-bottom: 30px;
    }

    .requests-section h2 {
      color: #7B61FF;
      margin-top: 0;
    }

    .request-card {
      background: #0F0F14;
      border: 1px solid #7B61FF;
      border-radius: 8px;
      padding: 20px;
      margin-bottom: 15px;
    }

    .request-header {
      display: flex;
      justify-content: space-between;
      align-items: start;
      margin-bottom: 15px;
    }

    .request-title {
      color: #00D1FF;
      font-size: 1.2em;
      font-weight: bold;
      margin: 0;
    }

    .request-meta {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 15px;
      margin: 15px 0;
      font-size: 0.9em;
    }

    .meta-item {
      display: flex;
      flex-direction: column;
    }

    .meta-label {
      color: #999;
      font-size: 0.8em;
      text-transform: uppercase;
    }

    .meta-value {
      color: #EAEAEA;
      margin-top: 3px;
    }

    .status-badge {
      display: inline-block;
      padding: 5px 10px;
      border-radius: 4px;
      font-size: 0.85em;
      font-weight: bold;
    }

    .status-pending {
      background: rgba(255, 122, 0, 0.2);
      color: #FF7A00;
    }

    .status-approved {
      background: rgba(0, 209, 255, 0.2);
      color: #00D1FF;
    }

    .status-rejected {
      background: rgba(255, 0, 0, 0.2);
      color: #ff6b6b;
    }

    .status-completed {
      background: rgba(76, 175, 80, 0.2);
      color: #4CAF50;
    }

    .request-description {
      background: rgba(123, 97, 255, 0.1);
      border-left: 3px solid #7B61FF;
      padding: 15px;
      margin: 15px 0;
      border-radius: 4px;
    }

    .request-description p {
      margin: 0;
      color: #EAEAEA;
    }

    .action-buttons {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .btn {
      padding: 8px 16px;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-size: 0.9em;
      font-weight: bold;
      transition: all 0.3s;
    }

    .btn-approve {
      background: #4CAF50;
      color: white;
    }

    .btn-approve:hover {
      background: #45a049;
    }

    .btn-reject {
      background: #ff6b6b;
      color: white;
    }

    .btn-reject:hover {
      background: #ff5252;
    }

    .btn-complete {
      background: #7B61FF;
      color: white;
    }

    .btn-complete:hover {
      background: #6a4df5;
    }

    .empty-state {
      text-align: center;
      padding: 40px;
      color: #999;
    }

    @media (max-width: 768px) {
      .admin-nav {
        flex-direction: column;
      }

      .admin-nav a {
        width: 100%;
        text-align: center;
      }

      .request-meta {
        grid-template-columns: 1fr;
      }

      .request-header {
        flex-direction: column;
      }

      .action-buttons {
        flex-direction: column;
      }

      .btn {
        width: 100%;
        text-align: center;
      }
    }
  </style>
</head>
<body>
  <div class="admin-container">
    <div class="admin-header">
      <h1>📅 Session Requests</h1>
      <p style="margin: 10px 0 0 0; color: #999;">Manage 1-on-1 session requests from students</p>
      <div class="admin-nav">
        <a href="/admin">📊 Dashboard</a>
        <a href="/admin/users">👥 Users</a>
        <a href="/admin/payments">💰 Payments</a>
        <a href="/admin/scripts">📝 Scripts</a>
        <a href="/admin/lessons">🎓 Lessons</a>
        <a href="/admin/session-requests" style="background: #7B61FF; color: #0F0F14;">📅 Sessions</a>
        <a href="/admin/messages">💬 Messages</a>
        <a href="/admin/certifications">🏆 Certificates</a>
        <a href="/admin/logs">📋 Logs</a>
        <a href="/auth/logout" style="background: #ff6b6b; color: white; border: 1px solid #ff6b6b;">🚪 Logout</a>
      </div>
    </div>

    <div class="requests-section">
      <h2>Pending & Active Requests</h2>
      
      <% if (requests && requests.length > 0) { %>
        <% requests.forEach(request => { %>
          <div class="request-card">
            <div class="request-header">
              <h3 class="request-title"><%= request.title %></h3>
              <span class="status-badge status-<%= request.status %>">
                <%= request.status.toUpperCase() %>
              </span>
            </div>

            <div class="request-meta">
              <div class="meta-item">
                <span class="meta-label">Student</span>
                <span class="meta-value"><%= request.username %></span>
              </div>
              <div class="meta-item">
                <span class="meta-label">Email</span>
                <span class="meta-value"><%= request.email || 'N/A' %></span>
              </div>
              <div class="meta-item">
                <span class="meta-label">Requested</span>
                <span class="meta-value"><%= new Date(request.created_at).toLocaleDateString() %></span>
              </div>
              <% if (request.scheduled_at) { %>
                <div class="meta-item">
                  <span class="meta-label">Scheduled For</span>
                  <span class="meta-value"><%= new Date(request.scheduled_at).toLocaleString() %></span>
                </div>
              <% } %>
            </div>

            <div class="request-description">
              <p><strong>Description:</strong> <%= request.description || 'No description provided' %></p>
            </div>

            <% if (request.notes) { %>
              <div class="request-description">
                <p><strong>Notes:</strong> <%= request.notes %></p>
              </div>
            <% } %>

            <div class="action-buttons">
              <% if (request.status === 'pending') { %>
                <button class="btn btn-approve" onclick="scheduleSession(<%= request.id %>)">✓ Approve & Schedule</button>
                <button class="btn btn-reject" onclick="rejectSession(<%= request.id %>)">✗ Reject</button>
              <% } else if (request.status === 'approved') { %>
                <button class="btn btn-complete" onclick="completeSession(<%= request.id %>)">✓ Mark Complete</button>
              <% } %>
            </div>
          </div>
        <% }); %>
      <% } else { %>
        <div class="empty-state">
          <p>📭 No session requests yet!</p>
        </div>
      <% } %>
    </div>
  </div>

  <script>
    function scheduleSession(requestId) {
      const dateTime = prompt('Enter session date/time (YYYY-MM-DD HH:MM):');
      if (!dateTime) return;

      const notes = prompt('Enter any notes (optional):');

      fetch(`/admin/session-requests/${requestId}/approve`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ 
          scheduled_at: dateTime,
          notes: notes || ''
        })
      })
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          alert('Session scheduled!');
          location.reload();
        } else {
          alert('Error: ' + data.error);
        }
      })
      .catch(e => alert('Error: ' + e.message));
    }

    function rejectSession(requestId) {
      const notes = prompt('Enter rejection reason:');
      if (!notes) return;

      fetch(`/admin/session-requests/${requestId}/reject`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ notes })
      })
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          alert('Session request rejected!');
          location.reload();
        } else {
          alert('Error: ' + data.error);
        }
      })
      .catch(e => alert('Error: ' + e.message));
    }

    function completeSession(requestId) {
      const notes = prompt('Enter completion notes (optional):');

      fetch(`/admin/session-requests/${requestId}/complete`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ notes: notes || '' })
      })
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          alert('Session marked as completed!');
          location.reload();
        } else {
          alert('Error: ' + data.error);
        }
      })
      .catch(e => alert('Error: ' + e.message));
    }
  </script>
</body>
</html>
