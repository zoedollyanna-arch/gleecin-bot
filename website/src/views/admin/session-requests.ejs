<%- include('../partials/admin-header', { title: 'Session Requests' }) %>

<main class="admin-shell">
  <section class="admin-panel">
    <div class="admin-panel-header">
      <div>
        <p class="admin-eyebrow">Session workflow</p>
        <h1>Sessions</h1>
        <p class="admin-muted">Approve, reject, schedule, and complete session requests with a unified admin interface.</p>
      </div>
    </div>

    <% if (Array.isArray(requests) && requests.length > 0) { %>
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Student</th>
              <th>Title</th>
              <th>Status</th>
              <th>Requested</th>
              <th>Scheduled</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% requests.forEach((request) => { %>
              <tr>
                <td><%= request.username || 'Student' %></td>
                <td><strong><%= request.title %></strong><p class="admin-muted"><%= request.description || '' %></p></td>
                <td><span class="admin-pill"><%= request.status || 'pending' %></span></td>
                <td><%= request.created_at ? new Date(request.created_at).toLocaleString() : '—' %></td>
                <td><%= request.scheduled_at ? new Date(request.scheduled_at).toLocaleString() : '—' %></td>
                <td>
                  <div class="admin-row-actions">
                    <% if (request.status === 'pending') { %>
                      <button class="admin-btn admin-btn-primary admin-btn-sm" type="button" data-session-action="approve" data-session-id="<%= request.id %>">Approve</button>
                      <button class="admin-btn admin-btn-secondary admin-btn-sm" type="button" data-session-action="reject" data-session-id="<%= request.id %>">Reject</button>
                    <% } else if (request.status === 'approved') { %>
                      <button class="admin-btn admin-btn-primary admin-btn-sm" type="button" data-session-action="complete" data-session-id="<%= request.id %>">Complete</button>
                    <% } else { %>
                      <span class="admin-muted">No actions</span>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p class="admin-empty">No session requests yet!</p>
    <% } %>
  </section>
</main>

<script>
  async function postSessionAction(sessionId, action, payload = {}) {
    const response = await fetch(`/admin/session-requests/${sessionId}/${action}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    return response.json();
  }

  function bindSessionActions() {
    document.querySelectorAll('[data-session-action]').forEach((button) => {
      button.addEventListener('click', async () => {
        const { sessionAction, sessionId } = button.dataset;

        try {
          let payload = {};
          if (sessionAction === 'approve') {
            const scheduledAt = prompt('Enter session date/time (YYYY-MM-DD HH:MM):');
            if (!scheduledAt) return;
            const notes = prompt('Enter any notes (optional):') || '';
            payload = { scheduled_at: scheduledAt, notes };
          }

          if (sessionAction === 'reject') {
            const notes = prompt('Enter rejection reason:');
            if (!notes) return;
            payload = { notes };
          }

          if (sessionAction === 'complete') {
            const notes = prompt('Enter completion notes (optional):') || '';
            payload = { notes };
          }

          const data = await postSessionAction(sessionId, sessionAction, payload);
          if (data.success) {
            alert('Session updated!');
            location.reload();
          } else {
            alert('Error: ' + (data.error || 'Failed'));
          }
        } catch (error) {
          alert('Error: ' + error.message);
        }
      });
    });
  }

  bindSessionActions();
</script>

<%- include('../partials/admin-footer') %>
