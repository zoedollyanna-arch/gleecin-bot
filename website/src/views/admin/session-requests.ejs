<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Session Requests - Admin</title>
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    .admin-container { background: linear-gradient(135deg, #0F0F14 0%, #1a1a22 100%); color: #EAEAEA; min-height: 100vh; padding: 20px; }
    .admin-header { background: #1a1a22; border-bottom: 2px solid #7B61FF; padding: 20px; margin-bottom: 30px; border-radius: 8px; }
    .admin-header h1 { color: #7B61FF; margin: 0; font-size: 2em; }
    .admin-nav { display: flex; gap: 10px; margin-top: 15px; flex-wrap: wrap; }
    .admin-nav a { background: #0F0F14; color: #00D1FF; padding: 10px 15px; border-radius: 6px; text-decoration: none; border: 1px solid #7B61FF; transition: all 0.3s; }
    .admin-nav a:hover, .admin-nav a.active { background: #7B61FF; color: #0F0F14; }
    .content-section { background: #1a1a22; border: 2px solid #7B61FF; border-radius: 8px; padding: 25px; margin-bottom: 30px; }
    .content-section h2 { color: #7B61FF; margin-top: 0; }
    .requests-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(400px, 1fr)); gap: 20px; margin-top: 20px; }
    .request-card { background: #0F0F14; border: 2px solid #7B61FF; border-radius: 8px; padding: 20px; }
    .request-status { display: inline-block; padding: 5px 10px; border-radius: 20px; font-weight: bold; font-size: 0.85em; }
    .status-pending { background: rgba(255, 193, 7, 0.2); color: #ffc107; }
    .status-approved { background: rgba(40, 167, 69, 0.2); color: #28a745; }
    .status-rejected { background: rgba(220, 53, 69, 0.2); color: #dc3545; }
    .action-buttons { display: flex; gap: 10px; margin-top: 15px; }
    .action-btn { padding: 8px 16px; border: none; border-radius: 6px; cursor: pointer; font-weight: bold; transition: all 0.3s; flex: 1; }
    .btn-approve { background: #28a745; color: white; }
    .btn-approve:hover { background: #218838; }
    .btn-reject { background: #dc3545; color: white; }
    .btn-reject:hover { background: #c82333; }
    .empty-state { text-align: center; padding: 40px; color: #999; }
  </style>
</head>
<body>
  <div class="admin-container">
    <div class="admin-header">
      <h1>👨‍💼 Admin Dashboard</h1>
      <p style="margin: 10px 0 0 0; color: #999;">Logged in as: <strong><%= user.username %></strong></p>
      <div class="admin-nav">
        <a href="/admin">📊 Dashboard</a>
        <a href="/admin/users">👥 Users</a>
        <a href="/admin/payments">💰 Payments</a>
        <a href="/admin/scripts">📝 Scripts</a>
        <a href="/admin/lessons">🎓 Lessons</a>
        <a href="/admin/session-requests" class="active">1️⃣ Sessions</a>
        <a href="/admin/logs">📋 Logs</a>
        <a href="/auth/logout" style="background: #ff6b6b; color: white;">🚪 Logout</a>
      </div>
    </div>

    <div class="content-section">
      <h2>1️⃣ 1-on-1 Session Requests</h2>
      <% if (sessions && sessions.length > 0) { %>
        <div class="requests-grid">
          <% sessions.forEach(session => { %>
            <div class="request-card">
              <div>
                <strong><%= session.student_name %></strong>
                <span class="request-status status-<%= session.status %>"><%= session.status.toUpperCase() %></span>
              </div>
              <div style="margin: 15px 0;">
                <strong>Topic:</strong> <%= session.topic %>
              </div>
              <div style="margin-bottom: 15px;">
                <strong>Preferred Time:</strong> <%= new Date(session.preferred_time).toLocaleString() %>
              </div>
              <div style="margin-bottom: 15px;">
                <strong>Duration:</strong> <%= session.duration %> minutes
              </div>
              <div style="font-size: 0.9em; color: #999; margin-bottom: 20px;">
                <strong>Requested:</strong> <%= new Date(session.created_at).toLocaleString() %>
              </div>
              
<% if (session.status === 'pending') { %>
                <div class="action-buttons">
                  <button class="action-btn btn-approve" onclick="approveSession(<%= session.id %>)">
                    ✓ Approve
                  </button>
                  <button class="action-btn btn-reject" onclick="rejectSession(<%= session.id %>)">
                    ✗ Reject
                  </button>
                </div>
              <% } else { %>
                <div style="padding: 8px 12px; background: rgba(100, 100, 100, 0.3); border-radius: 6px; font-size: 0.9em;">
                  <%= session.status === 'approved' ? '✅ Approved' : '❌ Rejected' %>
                  <% if (session.admin_notes) { %>
                    <br><small><%= session.admin_notes %></small>
                  <% } %>
                </div>
              <% } %>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <div class="empty-state">
          <h3>📭 No session requests</h3>
          <p>Students can request 1-on-1 sessions from their dashboard.</p>
        </div>
      <% } %>
    </div>
  </div>

  <script>
    async function approveSession(id) {
      if (confirm('Approve this session request?')) {
        try {
          const res = await fetch(`/admin/session-requests/${id}/approve`, { method: 'POST' });
          const data = await res.json();
          if (data.success) {
            location.reload();
          } else {
            alert('Error: ' + data.error);
          }
        } catch (error) {
          alert('Error approving session');
        }
      }
    }

    async function rejectSession(id) {
      if (confirm('Reject this session request?')) {
        // Add reject endpoint logic here
        alert('Reject feature coming soon!');
      }
    }
  </script>
</body>
</html>
