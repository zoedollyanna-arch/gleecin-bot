<%- include('../partials/admin-header', { title: 'Manage Lessons' }) %>

<main class="admin-shell">
  <section class="admin-panel">
    <div class="admin-panel-header">
      <div>
        <p class="admin-eyebrow">Lesson builder</p>
        <h1>Lessons</h1>
        <p class="admin-muted">Create lessons with uploaded video support, then monitor student progress from the same screen.</p>
      </div>
    </div>

    <form class="admin-form" action="/admin/lessons/create" method="post" enctype="multipart/form-data">
      <div class="admin-form-grid">
        <label class="admin-field">
          <span>Title</span>
          <input name="title" type="text" required>
        </label>
        <label class="admin-field">
          <span>Level</span>
          <select name="level" required>
            <option value="">Select level</option>
            <option value="beginner">Beginner</option>
            <option value="intermediate">Intermediate</option>
            <option value="advanced">Advanced</option>
          </select>
        </label>
        <label class="admin-field">
          <span>Duration</span>
          <input name="duration" type="text" placeholder="45 minutes" required>
        </label>
        <label class="admin-field">
          <span>Tier</span>
          <select name="tier" required>
            <option value="">Select tier</option>
            <option value="free">Free</option>
            <option value="paid">Paid</option>
            <option value="advanced">Advanced</option>
          </select>
        </label>
        <label class="admin-field admin-field-full">
          <span>Lesson description</span>
          <textarea name="description" rows="4" required></textarea>
        </label>
        <label class="admin-field">
          <span>Video source</span>
          <select name="video_source" data-lesson-video-source>
            <option value="upload">Upload video file</option>
            <option value="youtube">YouTube URL</option>
            <option value="vimeo">Vimeo URL</option>
            <option value="google_drive">Google Drive URL</option>
          </select>
        </label>
        <label class="admin-field" data-lesson-video-upload>
          <span>Upload video</span>
          <input name="video_file" type="file" accept="video/*">
        </label>
        <label class="admin-field" data-lesson-video-url hidden>
          <span>Video URL</span>
          <input name="video_url" type="url" placeholder="https://...">
        </label>
      </div>
      <div class="admin-form-actions">
        <button class="admin-btn admin-btn-primary" type="submit">Save lesson</button>
      </div>
    </form>
  </section>

  <section class="admin-panel">
    <div class="admin-panel-header">
      <h2>Published lessons</h2>
    </div>
    <% if (Array.isArray(lessons) && lessons.length) { %>
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Lesson</th>
              <th>Video</th>
              <th>Progress</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% lessons.forEach((lesson) => { %>
              <tr>
                <td>
                  <strong><%= lesson.title %></strong>
                  <p class="admin-muted"><%= lesson.creator || 'Admin' %></p>
                </td>
                <td><%= lesson.video_url ? 'URL' : (lesson.video_path ? 'Upload' : '—') %></td>
                <td><%= lesson.progress_count ?? lesson.progress ?? 0 %></td>
                <td>
                  <div class="admin-row-actions">
                    <a class="admin-link" href="/admin/lessons/<%= lesson.id %>">Edit</a>
                    <button class="admin-link-button" type="button" data-lesson-progress="<%= lesson.id %>">View progress</button>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p class="admin-empty">No lessons yet.</p>
    <% } %>
  </section>

  <section class="admin-panel">
    <div class="admin-panel-header">
      <h2>Student progress</h2>
    </div>
    <% if (Array.isArray(progress) && progress.length) { %>
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Student</th>
              <th>Lesson</th>
              <th>Started</th>
              <th>Completed</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% progress.forEach((item) => { %>
              <tr>
                <td><%= item.student_name || item.student || 'Student' %></td>
                <td><%= item.lesson_title || item.lesson || 'Lesson' %></td>
                <td><%= item.started_at ? new Date(item.started_at).toLocaleString() : '—' %></td>
                <td><%= item.completed_at ? new Date(item.completed_at).toLocaleString() : '—' %></td>
                <td><span class="admin-pill"><%= item.status || 'In progress' %></span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p class="admin-empty">No progress records found.</p>
    <% } %>
  </section>
</main>

<script>
  (() => {
    const source = document.querySelector('[data-lesson-video-source]');
    const upload = document.querySelector('[data-lesson-video-upload]');
    const url = document.querySelector('[data-lesson-video-url]');
    if (!source || !upload || !url) return;
    const toggle = () => {
      const isUpload = source.value === 'upload';
      upload.hidden = !isUpload;
      url.hidden = isUpload;
      upload.querySelector('input').required = isUpload;
      url.querySelector('input').required = !isUpload;
    };
    source.addEventListener('change', toggle);
    toggle();
  })();
</script>

<%- include('../partials/admin-footer') %>
