<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lesson Management - Admin</title>
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    .admin-container {
      background: linear-gradient(135deg, #0F0F14 0%, #1a1a22 100%);
      color: #EAEAEA;
      min-height: 100vh;
      padding: 20px;
    }

    .admin-header {
      background: #1a1a22;
      border-bottom: 2px solid #7B61FF;
      padding: 20px;
      margin-bottom: 30px;
      border-radius: 8px;
    }

    .admin-header h1 {
      color: #7B61FF;
      margin: 0;
      font-size: 2em;
    }

    .admin-nav {
      display: flex;
      gap: 10px;
      margin-top: 15px;
      flex-wrap: wrap;
    }

    .admin-nav a {
      background: #0F0F14;
      color: #00D1FF;
      padding: 10px 15px;
      border-radius: 6px;
      text-decoration: none;
      border: 1px solid #7B61FF;
      transition: all 0.3s;
    }

    .admin-nav a:hover,
    .admin-nav a.active {
      background: #7B61FF;
      color: #0F0F14;
    }

    .content-section {
      background: #1a1a22;
      border: 2px solid #7B61FF;
      border-radius: 8px;
      padding: 25px;
      margin-bottom: 30px;
    }

    .content-section h2 {
      color: #7B61FF;
      margin-top: 0;
    }

    .lesson-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 20px;
      margin-top: 20px;
    }

    .lesson-card {
      background: #0F0F14;
      border: 2px solid #7B61FF;
      border-radius: 8px;
      padding: 20px;
      transition: all 0.3s;
    }

    .lesson-card:hover {
      border-color: #00D1FF;
      box-shadow: 0 0 15px rgba(0, 209, 255, 0.3);
    }

    .lesson-title {
      color: #00D1FF;
      font-size: 1.2em;
      font-weight: bold;
      margin-bottom: 10px;
    }

    .lesson-level {
      display: inline-block;
      background: rgba(123, 97, 255, 0.2);
      color: #7B61FF;
      padding: 4px 8px;
      border-radius: 4px;
      font-size: 0.85em;
      margin-bottom: 10px;
    }

    .lesson-creator {
      color: #999;
      font-size: 0.9em;
      margin-bottom: 10px;
    }

    .lesson-description {
      color: #AAAAAA;
      font-size: 0.95em;
      margin-bottom: 15px;
      max-height: 80px;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .lesson-meta {
      display: flex;
      gap: 10px;
      margin-bottom: 15px;
      font-size: 0.9em;
      flex-wrap: wrap;
    }

    .meta-item {
      color: #999;
    }

    .meta-item strong {
      color: #00D1FF;
    }

    .tier-badge {
      display: inline-block;
      padding: 4px 8px;
      border-radius: 4px;
      font-size: 0.8em;
      font-weight: bold;
    }

    .tier-free {
      background: rgba(170, 170, 170, 0.2);
      color: #AAAAAA;
    }

    .tier-paid {
      background: rgba(123, 97, 255, 0.2);
      color: #7B61FF;
    }

    .tier-advanced {
      background: rgba(0, 209, 255, 0.2);
      color: #00D1FF;
    }

    .action-btn {
      background: #7B61FF;
      color: #0F0F14;
      padding: 6px 12px;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-size: 0.85em;
      font-weight: bold;
      transition: all 0.3s;
      margin-top: 10px;
      width: 100%;
      text-align: center;
    }

    .action-btn:hover {
      background: #00D1FF;
      color: #0F0F14;
    }

    .action-btn.delete {
      background: #FF4D4D;
      color: white;
      margin-top: 5px;
    }

    .action-btn.delete:hover {
      background: #ff3333;
    }

    .empty-state {
      text-align: center;
      padding: 40px;
      color: #999;
    }

    .create-section {
      background: #0F0F14;
      border: 2px dashed #7B61FF;
      padding: 30px;
      border-radius: 8px;
      margin-bottom: 30px;
    }

    .create-section h3 {
      color: #7B61FF;
      margin-bottom: 20px;
    }

    .form-group {
      margin-bottom: 15px;
    }

    .form-group input,
    .form-group textarea,
    .form-group select {
      width: 100%;
      padding: 10px;
      background: #1a1a22;
      color: #EAEAEA;
      border: 1px solid #7B61FF;
      border-radius: 6px;
      font-family: inherit;
    }

    .form-group select {
      cursor: pointer;
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 15px;
    }

    @media (max-width: 768px) {
      .admin-nav {
        flex-direction: column;
      }

      .admin-nav a {
        width: 100%;
        text-align: center;
      }

      .lesson-grid {
        grid-template-columns: 1fr;
      }

      .form-row {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <div class="admin-container">
    <div class="admin-header">
      <h1>👨‍💼 Admin Dashboard</h1>
      <p style="margin: 10px 0 0 0; color: #999;">Logged in as: <strong><%= user.username %></strong></p>
      <div class="admin-nav">
        <a href="/admin">📊 Dashboard</a>
        <a href="/admin/users">👥 Users</a>
        <a href="/admin/payments">💰 Payments</a>
        <a href="/admin/scripts">📝 Scripts</a>
        <a href="/admin/lessons" class="active">🎓 Lessons</a>
        <a href="/admin/session-requests">📅 Sessions</a>
        <a href="/admin/messages">💬 Messages</a>
        <a href="/admin/certifications">🏆 Certificates</a>
        <a href="/admin/logs">📋 Logs</a>
        <a href="/auth/logout" style="background: #ff6b6b; color: white; border: 1px solid #ff6b6b;">🚪 Logout</a>
      </div>
    </div>

    <!-- Create Lesson Section -->
    <div class="content-section">
      <h2>🎬 Create New Lesson</h2>
      <div class="create-section">
        <h3>📝 Add Video Lesson</h3>
        <form id="createLessonForm">
          <div class="form-row">
            <div class="form-group">
              <label style="color: #00D1FF;">Lesson Title *</label>
              <input type="text" name="title" placeholder="Enter lesson title" required>
            </div>
            <div class="form-group">
              <label style="color: #00D1FF;">Duration (minutes) *</label>
              <input type="number" name="duration" placeholder="e.g., 45" min="1" required>
            </div>
          </div>

          <div class="form-group">
            <label style="color: #00D1FF;">Description *</label>
            <textarea name="description" placeholder="Lesson description" required></textarea>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label style="color: #00D1FF;">Level *</label>
              <select name="level" required>
                <option value="">Select level</option>
                <option value="beginner">Beginner</option>
                <option value="intermediate">Intermediate</option>
                <option value="advanced">Advanced</option>
              </select>
            </div>
            <div class="form-group">
              <label style="color: #00D1FF;">Tier *</label>
              <select name="tier" required>
                <option value="free">Free</option>
                <option value="paid">Paid</option>
                <option value="advanced">Advanced</option>
              </select>
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label style="color: #00D1FF;">Video Type *</label>
              <select name="video_type" required>
                <option value="">Select type</option>
                <option value="youtube">YouTube</option>
                <option value="vimeo">Vimeo</option>
                <option value="google_drive">Google Drive</option>
                <option value="uploaded">Uploaded File</option>
              </select>
            </div>
            <div class="form-group">
              <label style="color: #00D1FF;">Video URL *</label>
              <input type="url" name="video_url" placeholder="https://..." required>
            </div>
          </div>

          <button type="submit" class="action-btn" style="width: auto;">🎬 Create Lesson</button>
        </form>
      </div>
    </div>

    <!-- Lessons Management -->
    <div class="content-section">
      <h2>🎓 Lesson Management</h2>

      <% if (lessons && lessons.length > 0) %>
        <div class="lesson-grid">
          <% lessons.forEach(lesson => { %>
            <div class="lesson-card">
              <div class="lesson-title"><%= lesson.title %></div>
              <div class="lesson-level"><%= lesson.level %></div>
              <div class="lesson-creator">By: <strong><%= lesson.creator || 'Admin' %></strong></div>
              <div class="lesson-description"><%= lesson.description || 'No description' %></div>
              
              <div class="lesson-meta">
                <div class="meta-item">⏱️ <strong><%= lesson.duration || 'N/A' %></strong> min</div>
                <div class="meta-item">🎬 <strong><%= lesson.video_type || 'N/A' %></strong></div>
              </div>

              <div>
                <span class="tier-badge tier-<%= lesson.price_tier %>">
                  <%= lesson.price_tier.toUpperCase() %>
                </span>
              </div>

              <button class="action-btn" onclick="editLesson(<%= lesson.id %>)">✏️ Edit</button>
              <button class="action-btn delete" onclick="deleteLesson(<%= lesson.id %>)">🗑️ Delete</button>
            </div>
          <% }); %>
        </div>
      <% } else %>
        <div class="empty-state">
          <p>📭 No lessons created yet</p>
          <p>Create your first lesson to get started!</p>
        </div>
      <% end %>
    </div>
  </div>

  <script>
    document.getElementById('createLessonForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(e.target);
      const data = Object.fromEntries(formData);
      
      fetch('/admin/lessons/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      })
      .then(res => res.json())
      .then(data => {
        if (data.success) {
          alert('✓ Lesson created successfully');
          location.reload();
        } else {
          alert('✗ Error: ' + data.error);
        }
      })
      .catch(err => {
        console.error('Error:', err);
        alert('✗ Failed to create lesson');
      });
    });

    function editLesson(lessonId) {
      alert('Edit feature coming soon!');
    }

    function deleteLesson(lessonId) {
      if (confirm('Are you sure you want to delete this lesson?')) {
        alert('Delete feature coming soon!');
      }
    }
  </script>
</body>
</html>
