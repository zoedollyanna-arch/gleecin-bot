<%- include('../partials/admin-header', { title: 'Quiz Management' }) %>

<% const safeLessons = Array.isArray(lessons) ? lessons : []; %>
<% const safeQuizzes = Array.isArray(quizzes) ? quizzes : []; %>
<% const safeQuestions = Array.isArray(questions) ? questions : []; %>
<% const safeAttempts = Array.isArray(attempts) ? attempts : []; %>

<main class="admin-shell">
  <section class="admin-panel">
    <div class="admin-panel-header">
      <div>
        <p class="admin-eyebrow">Quiz management</p>
        <h1>Quizzes</h1>
        <p class="admin-muted">Create quizzes, edit them inline, and review questions and student attempts from the same admin workflow.</p>
      </div>
    </div>

    <form class="admin-form" id="createQuizForm">
      <div class="admin-form-grid">
        <label class="admin-field">
          <span>Title</span>
          <input name="title" type="text" placeholder="Quiz title" required>
        </label>
        <label class="admin-field">
          <span>Lesson</span>
          <select name="lesson_id">
            <option value="">Unlinked</option>
            <% if (safeLessons.length) { %>
              <% safeLessons.forEach((lesson) => { %>
                <option value="<%= lesson.id %>"><%= lesson.title %></option>
              <% }) %>
            <% } %>
          </select>
        </label>
        <label class="admin-field">
          <span>Difficulty</span>
          <select name="difficulty">
            <option value="">Select difficulty</option>
            <option value="easy">Easy</option>
            <option value="medium">Medium</option>
            <option value="hard">Hard</option>
          </select>
        </label>
        <label class="admin-field">
          <span>Tier</span>
          <select name="price_tier" required>
            <option value="free">Free</option>
            <option value="paid">Paid</option>
            <option value="advanced">Advanced</option>
          </select>
        </label>
        <label class="admin-field">
          <span>Passing score</span>
          <input name="passing_score" type="number" min="1" max="100" value="70">
        </label>
        <label class="admin-field">
          <span>Time limit minutes</span>
          <input name="time_limit_minutes" type="number" min="1" placeholder="Optional">
        </label>
        <label class="admin-field admin-field-full">
          <span>Description</span>
          <textarea name="description" rows="4" placeholder="Quiz description"></textarea>
        </label>
      </div>
      <div class="admin-form-actions">
        <button class="admin-btn admin-btn-primary" type="submit">Create quiz</button>
      </div>
    </form>
  </section>

  <section class="admin-panel">
    <div class="admin-panel-header">
      <h2>Quizzes</h2>
      <p class="admin-muted">Edit, update, and delete quiz content from this dashboard.</p>
    </div>

    <% if (Array.isArray(quizzes) && quizzes.length) { %>
      <div class="admin-grid admin-grid-2">
        <% quizzes.forEach((quiz) => { %>
          <article class="admin-info-card" data-quiz-card data-quiz-id="<%= quiz.id %>">
            <h3><%= quiz.title %></h3>
            <p class="admin-muted">Lesson: <%= quiz.lesson_title || 'Unlinked' %></p>
            <p class="admin-muted">Creator: <%= quiz.creator || 'Admin' %></p>
            <p class="admin-muted"><%= quiz.description || 'No description' %></p>
            <p class="admin-muted">Questions: <%= quiz.question_count ?? 0 %> · Attempts: <%= quiz.attempt_count ?? 0 %></p>
            <p class="admin-muted">Passing score: <%= quiz.passing_score ?? 70 %> · Time limit: <%= quiz.time_limit_minutes || 'No limit' %> mins</p>
            <span class="admin-pill"><%= String(quiz.price_tier || 'free').toUpperCase() %></span>

            <form class="admin-form admin-quiz-edit-form" data-quiz-id="<%= quiz.id %>">
              <div class="admin-form-grid">
                <label class="admin-field"><span>Title</span><input name="title" type="text" value="<%= quiz.title %>" required></label>
                <label class="admin-field"><span>Lesson</span>
                  <select name="lesson_id">
                    <option value="">Unlinked</option>
                    <% if (safeLessons.length) { %>
                      <% safeLessons.forEach((lesson) => { %>
                        <option value="<%= lesson.id %>" <%= String(quiz.lesson_id || '') === String(lesson.id) ? 'selected' : '' %>><%= lesson.title %></option>
                      <% }) %>
                    <% } %>
                  </select>
                </label>
                <label class="admin-field"><span>Difficulty</span>
                  <select name="difficulty">
                    <option value="" <%= !quiz.difficulty ? 'selected' : '' %>>Select difficulty</option>
                    <option value="easy" <%= quiz.difficulty === 'easy' ? 'selected' : '' %>>Easy</option>
                    <option value="medium" <%= quiz.difficulty === 'medium' ? 'selected' : '' %>>Medium</option>
                    <option value="hard" <%= quiz.difficulty === 'hard' ? 'selected' : '' %>>Hard</option>
                  </select>
                </label>
                <label class="admin-field"><span>Tier</span>
                  <select name="price_tier">
                    <option value="free" <%= (quiz.price_tier || 'free') === 'free' ? 'selected' : '' %>>Free</option>
                    <option value="paid" <%= quiz.price_tier === 'paid' ? 'selected' : '' %>>Paid</option>
                    <option value="advanced" <%= quiz.price_tier === 'advanced' ? 'selected' : '' %>>Advanced</option>
                  </select>
                </label>
                <label class="admin-field"><span>Passing score</span><input name="passing_score" type="number" min="1" max="100" value="<%= quiz.passing_score ?? 70 %>"></label>
                <label class="admin-field"><span>Time limit minutes</span><input name="time_limit_minutes" type="number" min="1" value="<%= quiz.time_limit_minutes || '' %>"></label>
                <label class="admin-field admin-field-full"><span>Description</span><textarea name="description" rows="4"><%= quiz.description || '' %></textarea></label>
              </div>
              <div class="admin-form-actions">
                <button class="admin-btn admin-btn-primary" type="submit">Update quiz</button>
                <button class="admin-btn admin-btn-secondary" type="button" data-delete-quiz="<%= quiz.id %>">Delete</button>
              </div>
            </form>
          </article>
        <% }) %>
      </div>
    <% } else { %>
      <p class="admin-empty">No quizzes created yet.</p>
    <% } %>
  </section>

  <section class="admin-panel">
    <div class="admin-panel-header">
      <h2>Recent questions</h2>
    </div>

    <% if (Array.isArray(questions) && questions.length) { %>
      <div class="admin-list">
        <% questions.forEach((question) => { %>
          <article class="admin-list-item">
            <div>
              <strong><%= question.quiz_title %></strong>
              <p class="admin-muted"><%= question.question_text %></p>
            </div>
            <span class="admin-pill"><%= question.question_type || 'question' %></span>
          </article>
        <% }) %>
      </div>
    <% } else { %>
      <p class="admin-empty">No questions added yet.</p>
    <% } %>
  </section>

  <section class="admin-panel">
    <div class="admin-panel-header">
      <h2>Recent attempts</h2>
    </div>

    <% if (Array.isArray(attempts) && attempts.length) { %>
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Student</th>
              <th>Quiz</th>
              <th>Score</th>
              <th>Passed</th>
              <th>Attempted</th>
            </tr>
          </thead>
          <tbody>
            <% attempts.forEach((attempt) => { %>
              <tr>
                <td><%= attempt.student_name || 'Student' %></td>
                <td><%= attempt.quiz_title || 'Quiz' %></td>
                <td><%= attempt.score ?? 0 %></td>
                <td><span class="admin-pill"><%= attempt.passed ? 'Yes' : 'No' %></span></td>
                <td><%= attempt.attempted_at ? new Date(attempt.attempted_at).toLocaleString() : '—' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p class="admin-empty">No quiz attempts yet.</p>
    <% } %>
  </section>
</main>

<script>
  const createQuizForm = document.getElementById('createQuizForm');
  if (createQuizForm) {
    createQuizForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(e.target));
      const res = await fetch('/admin/quizzes/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      const json = await res.json();
      if (json.success) {
        alert('Quiz created');
        location.reload();
      } else {
        alert(json.error || 'Failed');
      }
    });
  }

  document.querySelectorAll('.admin-quiz-edit-form').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const quizId = form.dataset.quizId;
      const data = Object.fromEntries(new FormData(form));
      const res = await fetch(`/admin/quizzes/${quizId}/update`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      const json = await res.json();
      if (json.success) {
        alert('Quiz updated');
        location.reload();
      } else {
        alert(json.error || 'Failed to update quiz');
      }
    });
  });

  document.querySelectorAll('[data-delete-quiz]').forEach((button) => {
    button.addEventListener('click', async () => {
      const quizId = button.dataset.deleteQuiz;
      if (!confirm('Delete this quiz permanently?')) return;
      const res = await fetch(`/admin/quizzes/${quizId}/delete`, { method: 'POST' });
      const json = await res.json();
      if (json.success) {
        alert('Quiz deleted');
        location.reload();
      } else {
        alert(json.error || 'Failed to delete quiz');
      }
    });
  });
</script>

<%- include('../partials/admin-footer') %>
