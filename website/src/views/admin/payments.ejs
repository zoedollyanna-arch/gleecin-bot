<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Payment Management - Admin</title>
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    .admin-container {
      background: linear-gradient(135deg, #0F0F14 0%, #1a1a22 100%);
      color: #EAEAEA;
      min-height: 100vh;
      padding: 20px;
    }

    .admin-header {
      background: #1a1a22;
      border-bottom: 2px solid #7B61FF;
      padding: 20px;
      margin-bottom: 30px;
      border-radius: 8px;
    }

    .admin-header h1 {
      color: #7B61FF;
      margin: 0;
      font-size: 2em;
    }

    .admin-nav {
      display: flex;
      gap: 10px;
      margin-top: 15px;
      flex-wrap: wrap;
    }

    .admin-nav a {
      background: #0F0F14;
      color: #00D1FF;
      padding: 10px 15px;
      border-radius: 6px;
      text-decoration: none;
      border: 1px solid #7B61FF;
      transition: all 0.3s;
    }

    .admin-nav a:hover,
    .admin-nav a.active {
      background: #7B61FF;
      color: #0F0F14;
    }

    .content-section {
      background: #1a1a22;
      border: 2px solid #7B61FF;
      border-radius: 8px;
      padding: 25px;
      margin-bottom: 30px;
    }

    .content-section h2 {
      color: #7B61FF;
      margin-top: 0;
    }

    .filter-bar {
      display: flex;
      gap: 10px;
      margin-bottom: 20px;
      flex-wrap: wrap;
    }

    .filter-bar select {
      padding: 10px;
      background: #0F0F14;
      color: #EAEAEA;
      border: 1px solid #7B61FF;
      border-radius: 6px;
      cursor: pointer;
    }

    .filter-bar select:focus {
      outline: none;
      border-color: #00D1FF;
    }

    .payments-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 15px;
    }

    .payments-table th {
      background: #0F0F14;
      color: #00D1FF;
      padding: 12px;
      text-align: left;
      border-bottom: 2px solid #7B61FF;
      font-weight: bold;
    }

    .payments-table td {
      padding: 12px;
      border-bottom: 1px solid #333;
      color: #EAEAEA;
    }

    .payments-table tr:hover {
      background: rgba(123, 97, 255, 0.1);
    }

    .status-badge {
      display: inline-block;
      padding: 5px 10px;
      border-radius: 4px;
      font-size: 0.85em;
      font-weight: bold;
    }

    .status-pending {
      background: rgba(255, 122, 0, 0.2);
      color: #FF7A00;
    }

    .status-verified {
      background: rgba(0, 209, 255, 0.2);
      color: #00D1FF;
    }

    .status-rejected {
      background: rgba(255, 77, 77, 0.2);
      color: #FF4D4D;
    }

    .tier-badge {
      display: inline-block;
      padding: 5px 10px;
      border-radius: 4px;
      font-size: 0.85em;
      font-weight: bold;
    }

    .tier-paid {
      background: rgba(123, 97, 255, 0.2);
      color: #7B61FF;
    }

    .tier-advanced {
      background: rgba(0, 209, 255, 0.2);
      color: #00D1FF;
    }

    .action-btn {
      background: #7B61FF;
      color: #0F0F14;
      padding: 6px 12px;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-size: 0.85em;
      font-weight: bold;
      margin-right: 5px;
      transition: all 0.3s;
    }

    .action-btn:hover {
      background: #00D1FF;
      color: #0F0F14;
    }

    .action-btn.reject {
      background: #FF4D4D;
      color: white;
    }

    .action-btn.reject:hover {
      background: #ff3333;
    }

    .action-btn:disabled {
      background: #666;
      color: #999;
      cursor: not-allowed;
      opacity: 0.5;
    }

    .empty-state {
      text-align: center;
      padding: 40px;
      color: #999;
    }

    .proof-text {
      max-width: 300px;
      word-wrap: break-word;
      font-family: monospace;
      font-size: 0.9em;
      color: #00D1FF;
    }

    @media (max-width: 768px) {
      .admin-nav {
        flex-direction: column;
      }

      .admin-nav a {
        width: 100%;
        text-align: center;
      }

      .payments-table {
        font-size: 0.9em;
      }

      .payments-table th,
      .payments-table td {
        padding: 8px;
      }

      .action-btn {
        padding: 4px 8px;
        font-size: 0.8em;
        margin-right: 2px;
      }
    }
  </style>
</head>
<body>
  <div class="admin-container">
    <div class="admin-header">
      <h1>👨‍💼 Admin Dashboard</h1>
      <p style="margin: 10px 0 0 0; color: #999;">Logged in as: <strong><%= user.username %></strong></p>
      <div class="admin-nav">
        <a href="/admin">📊 Dashboard</a>
        <a href="/admin/users">👥 Users</a>
        <a href="/admin/payments" class="active">💰 Payments</a>
        <a href="/admin/scripts">📝 Scripts</a>
        <a href="/admin/lessons">🎓 Lessons</a>
        <a href="/admin/session-requests">📅 Sessions</a>
        <a href="/admin/messages">💬 Messages</a>
        <a href="/admin/certifications">🏆 Certificates</a>
        <a href="/admin/logs">📋 Logs</a>
        <a href="/auth/logout" style="background: #ff6b6b; color: white; border: 1px solid #ff6b6b;">🚪 Logout</a>
      </div>
    </div>

    <!-- Payment Management -->
    <div class="content-section">
      <h2>💳 Payment Management</h2>

      <div class="filter-bar">
        <select id="statusFilter">
          <option value="">All Statuses</option>
          <option value="pending">⏳ Pending</option>
          <option value="verified">✓ Verified</option>
          <option value="rejected">✗ Rejected</option>
        </select>
        <select id="tierFilter">
          <option value="">All Tiers</option>
          <option value="paid">Paid Tier</option>
          <option value="advanced">Advanced Tier</option>
        </select>
      </div>

      <% if (payments && payments.length > 0) %>
        <table class="payments-table">
          <thead>
            <tr>
              <th>User</th>
              <th>Tier</th>
              <th>Amount</th>
              <th>Recipient</th>
              <th>Status</th>
              <th>Date</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="paymentsTableBody">
            <% payments.forEach(payment => { %>
              <tr class="payment-row" data-status="<%= payment.status %>" data-tier="<%= payment.tier %>">
                <td><strong><%= payment.username %></strong></td>
                <td>
                  <span class="tier-badge tier-<%= payment.tier %>">
                    <%= payment.tier.toUpperCase() %>
                  </span>
                </td>
                <td><strong><%= payment.amount_lindens %> L$</strong></td>
                <td>
                  <span class="proof-text"><%= payment.recipient || 'zoedollyanna resident' %></span>
                </td>
                <td>
                  <span class="status-badge status-<%= payment.status %>">
                    <% if (payment.status === 'pending') { %>⏳<% } else if (payment.status === 'verified') { %>✓<% } else { %>✗<% } %>
                    <%= payment.status.toUpperCase() %>
                  </span>
                </td>
                <td><%= new Date(payment.created_at).toLocaleDateString() %></td>
                <td>
                  <% if (payment.status === 'pending') { %>
                    <button class="action-btn" onclick="verifyPayment(<%= payment.id %>)">✓ Verify</button>
                    <button class="action-btn reject" onclick="rejectPayment(<%= payment.id %>)">✗ Reject</button>
                  <% } else { %>
                    <span style="color: #666;">Processed</span>
                  <% } %>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      <% } else { %>
        <div class="empty-state">
          <p>✓ No payments to display</p>
        </div>
      <% } %>
    </div>
  </div>

  <script>
    // Filter functionality
    document.getElementById('statusFilter').addEventListener('change', filterPayments);
    document.getElementById('tierFilter').addEventListener('change', filterPayments);

    function filterPayments() {
      const statusFilter = document.getElementById('statusFilter').value;
      const tierFilter = document.getElementById('tierFilter').value;
      const rows = document.querySelectorAll('.payment-row');

      rows.forEach(row => {
        const status = row.dataset.status;
        const tier = row.dataset.tier;

        const statusMatch = !statusFilter || status === statusFilter;
        const tierMatch = !tierFilter || tier === tierFilter;

        row.style.display = (statusMatch && tierMatch) ? '' : 'none';
      });
    }

    function verifyPayment(paymentId) {
      const notes = prompt('Enter verification notes (optional):');
      
      if (notes !== null) {
        fetch(`/admin/payments/${paymentId}/verify`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ notes })
        })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            alert('✓ Payment verified successfully');
            location.reload();
          } else {
            alert('✗ Error: ' + data.error);
          }
        })
        .catch(err => {
          console.error('Error:', err);
          alert('✗ Failed to verify payment');
        });
      }
    }

    function rejectPayment(paymentId) {
      const reason = prompt('Enter rejection reason:');
      
      if (reason) {
        fetch(`/admin/payments/${paymentId}/reject`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ reason })
        })
        .then(res => res.json())
        .then(data => {
          if (data.success) {
            alert('✓ Payment rejected');
            location.reload();
          } else {
            alert('✗ Error: ' + data.error);
          }
        })
        .catch(err => {
          console.error('Error:', err);
          alert('✗ Failed to reject payment');
        });
      }
    }
  </script>
</body>
</html>
