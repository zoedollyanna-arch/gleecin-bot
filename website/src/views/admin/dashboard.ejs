<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard</title>
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    .admin-container {
      background: linear-gradient(135deg, #0F0F14 0%, #1a1a22 100%);
      color: #EAEAEA;
      min-height: 100vh;
      padding: 20px;
    }

    .admin-header {
      background: #1a1a22;
      border-bottom: 2px solid #7B61FF;
      padding: 20px;
      margin-bottom: 30px;
      border-radius: 8px;
    }

    .admin-header h1 {
      color: #7B61FF;
      margin: 0;
      font-size: 2em;
    }

    .admin-nav {
      display: flex;
      gap: 10px;
      margin-top: 15px;
      flex-wrap: wrap;
    }

    .admin-nav a {
      background: #0F0F14;
      color: #00D1FF;
      padding: 10px 15px;
      border-radius: 6px;
      text-decoration: none;
      border: 1px solid #7B61FF;
      transition: all 0.3s;
    }

    .admin-nav a:hover {
      background: #7B61FF;
      color: #0F0F14;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
      margin-bottom: 40px;
    }

    .stat-card {
      background: #1a1a22;
      border: 2px solid #7B61FF;
      border-radius: 8px;
      padding: 25px;
      text-align: center;
    }

    .stat-number {
      font-size: 2.5em;
      color: #00D1FF;
      font-weight: bold;
      margin: 10px 0;
    }

    .stat-label {
      color: #EAEAEA;
      font-size: 0.95em;
    }

    .recent-payments {
      background: #1a1a22;
      border: 2px solid #7B61FF;
      border-radius: 8px;
      padding: 25px;
      margin-bottom: 30px;
    }

    .recent-payments h2 {
      color: #7B61FF;
      margin-top: 0;
    }

    .payments-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 15px;
    }

    .payments-table th {
      background: #0F0F14;
      color: #00D1FF;
      padding: 12px;
      text-align: left;
      border-bottom: 2px solid #7B61FF;
    }

    .payments-table td {
      padding: 12px;
      border-bottom: 1px solid #333;
      color: #EAEAEA;
    }

    .payments-table tr:hover {
      background: rgba(123, 97, 255, 0.1);
    }

    .status-badge {
      display: inline-block;
      padding: 5px 10px;
      border-radius: 4px;
      font-size: 0.85em;
      font-weight: bold;
    }

    .status-pending {
      background: rgba(255, 122, 0, 0.2);
      color: #FF7A00;
    }

    .status-verified {
      background: rgba(0, 209, 255, 0.2);
      color: #00D1FF;
    }

    .status-rejected {
      background: rgba(255, 0, 0, 0.2);
      color: #ff6b6b;
    }

    .action-btn {
      background: #7B61FF;
      color: #0F0F14;
      padding: 6px 12px;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-size: 0.85em;
      font-weight: bold;
      margin-right: 5px;
      transition: all 0.3s;
    }

    .action-btn:hover {
      background: #00D1FF;
      color: #0F0F14;
    }

    .action-btn.reject {
      background: #ff6b6b;
      color: white;
    }

    .action-btn.reject:hover {
      background: #ff5252;
    }

    .empty-state {
      text-align: center;
      padding: 40px;
      color: #999;
    }

    .empty-state p {
      font-size: 1.1em;
      margin: 10px 0;
    }

    @media (max-width: 768px) {
      .admin-nav {
        flex-direction: column;
      }

      .admin-nav a {
        width: 100%;
        text-align: center;
      }

      .stats-grid {
        grid-template-columns: 1fr;
      }

      .payments-table {
        font-size: 0.9em;
      }

      .payments-table th,
      .payments-table td {
        padding: 8px;
      }
    }
  </style>
</head>
<body>
  <div class="admin-container">
    <div class="admin-header">
      <h1>👨‍💼 Admin Dashboard</h1>
      <p style="margin: 10px 0 0 0; color: #999;">Logged in as: <strong><%= user.username %></strong></p>
      <div class="admin-nav">
        <a href="/admin">📊 Dashboard</a>
        <a href="/admin/users">👥 Users</a>
        <a href="/admin/payments">💰 Payments</a>
        <a href="/admin/scripts">📝 Scripts</a>
        <a href="/admin/lessons">🎓 Lessons</a>
        <a href="/admin/session-requests">📅 Sessions</a>
        <a href="/admin/messages">💬 Messages</a>
        <a href="/admin/certifications">🏆 Certificates</a>
        <a href="/admin/logs">📋 Logs</a>
        <a href="/auth/logout" style="background: #ff6b6b; color: white; border: 1px solid #ff6b6b;">🚪 Logout</a>
      </div>
    </div>

    <!-- Statistics -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-label">Total Users</div>
        <div class="stat-number"><%= stats.total_users %></div>
      </div>

      <div class="stat-card">
        <div class="stat-label">Paid Users</div>
        <div class="stat-number"><%= stats.paid_users %></div>
      </div>

      <div class="stat-card">
        <div class="stat-label">Pending Payments</div>
        <div class="stat-number" style="color: #FF7A00;"><%= stats.pending_payments %></div>
      </div>

      <div class="stat-card">
        <div class="stat-label">Scripts</div>
        <div class="stat-number"><%= stats.total_scripts %></div>
      </div>

      <div class="stat-card">
        <div class="stat-label">Lessons</div>
        <div class="stat-number"><%= stats.total_lessons %></div>
      </div>

      <div class="stat-card">
        <div class="stat-label">Certificates Issued</div>
        <div class="stat-number"><%= stats.issued_certs %></div>
      </div>
    </div>

    <!-- Recent Payments -->
    <div class="recent-payments">
      <h2>💳 Pending Payments</h2>

      <% if (recentPayments && recentPayments.length > 0) %>
        <table class="payments-table">
          <thead>
            <tr>
              <th>User</th>
              <th>Tier</th>
              <th>Amount</th>
              <th>Status</th>
              <th>Date</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% recentPayments.forEach(payment => { %>
              <tr>
                <td><%= payment.username %></td>
                <td><strong><%= payment.tier %></strong></td>
                <td><%= payment.amount_lindens %> L$</td>
                <td>
                  <span class="status-badge status-<%= payment.status %>">
                    <%= payment.status.toUpperCase() %>
                  </span>
                </td>
                <td><%= new Date(payment.created_at).toLocaleDateString() %></td>
                <td>
                  <button class="action-btn" onclick="verifyPayment(<%= payment.id %>)">✓ Verify</button>
                  <button class="action-btn reject" onclick="rejectPayment(<%= payment.id %>)">✗ Reject</button>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      <% else %>
        <div class="empty-state">
          <p>✓ All caught up! No pending payments.</p>
        </div>
      <% end %>
    </div>
  </div>

  <script>
    function verifyPayment(paymentId) {
      const notes = prompt('Enter verification notes (optional):');
      
      fetch(`/admin/payments/${paymentId}/verify`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ notes: notes || '' })
      })
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          alert('Payment verified!');
          location.reload();
        } else {
          alert('Error: ' + data.error);
        }
      })
      .catch(e => alert('Error: ' + e.message));
    }

    function rejectPayment(paymentId) {
      const reason = prompt('Enter rejection reason:');
      if (!reason) return;

      fetch(`/admin/payments/${paymentId}/reject`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ reason })
      })
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          alert('Payment rejected!');
          location.reload();
        } else {
          alert('Error: ' + data.error);
        }
      })
      .catch(e => alert('Error: ' + e.message));
    }
  </script>
</body>
</html>
