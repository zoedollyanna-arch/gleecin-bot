<%- include('../partials/admin-header', { title: 'Admin Dashboard' }) %>

<main class="admin-shell">
  <section class="admin-panel admin-hero">
    <div>
      <p class="admin-eyebrow">Operations overview</p>
      <h1>Admin dashboard</h1>
      <p class="admin-muted">Track lesson progress, student completion, challenge submissions, and inbox activity in one place.</p>
    </div>
    <div class="admin-hero-stats">
      <article class="admin-stat-card">
        <span class="admin-stat-label">Active lessons</span>
        <strong><%= typeof activeLessons !== 'undefined' ? activeLessons : (lessons?.length || 0) %></strong>
      </article>
      <article class="admin-stat-card">
        <span class="admin-stat-label">Pending messages</span>
        <strong><%= typeof pendingMessages !== 'undefined' ? pendingMessages : (messages?.length || 0) %></strong>
      </article>
      <article class="admin-stat-card">
        <span class="admin-stat-label">Challenge submissions</span>
        <strong><%= typeof challengeSubmissions !== 'undefined' ? challengeSubmissions : (submissions?.length || 0) %></strong>
      </article>
    </div>
  </section>

  <section class="admin-grid admin-grid-2">
    <div class="admin-panel">
      <div class="admin-panel-header">
        <h2>Recent progress</h2>
        <a class="admin-link" href="/admin/lessons">Manage lessons</a>
      </div>
      <% if (Array.isArray(recentProgress) && recentProgress.length) { %>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Student</th>
                <th>Lesson</th>
                <th>Status</th>
                <th>Completed</th>
              </tr>
            </thead>
            <tbody>
              <% recentProgress.forEach((item) => { %>
                <tr>
                  <td><%= item.student_name || item.student || 'Student' %></td>
                  <td><%= item.lesson_title || item.lesson || 'Lesson' %></td>
                  <td><span class="admin-pill admin-pill-<%= (item.status || 'in-progress').toLowerCase().replace(/[^a-z0-9]+/g, '-') %>"><%= item.status || 'In progress' %></span></td>
                  <td><%= item.completed_at ? new Date(item.completed_at).toLocaleString() : '—' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <p class="admin-empty">No progress data yet.</p>
      <% } %>
    </div>

    <div class="admin-panel">
      <div class="admin-panel-header">
        <h2>Latest inbox activity</h2>
        <a class="admin-link" href="/admin/messages">Open inbox</a>
      </div>
      <% if (Array.isArray(recentMessages) && recentMessages.length) { %>
        <div class="admin-list">
          <% recentMessages.forEach((message) => { %>
            <article class="admin-list-item">
              <div>
                <strong><%= message.subject || 'No subject' %></strong>
                <p class="admin-muted"><%= message.sender_name || message.sender || 'Student' %> · <%= message.created_at ? new Date(message.created_at).toLocaleString() : '' %></p>
              </div>
              <span class="admin-pill <%= message.replied_at ? 'admin-pill-success' : 'admin-pill-warning' %>"><%= message.replied_at ? 'Replied' : 'New' %></span>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <p class="admin-empty">No inbox activity yet.</p>
      <% } %>
    </div>
  </section>

  <section class="admin-panel">
    <div class="admin-panel-header">
      <h2>Certificates & completions</h2>
      <a class="admin-link" href="/admin/certifications">Manage certificates</a>
    </div>
    <div class="admin-grid admin-grid-3">
      <article class="admin-info-card">
        <h3>Issued certificates</h3>
        <p class="admin-muted"><%= typeof issuedCertificates !== 'undefined' ? issuedCertificates : (certifications?.length || 0) %> total</p>
      </article>
      <article class="admin-info-card">
        <h3>Pending review</h3>
        <p class="admin-muted"><%= typeof pendingReviews !== 'undefined' ? pendingReviews : (reviewQueue?.length || 0) %> items</p>
      </article>
      <article class="admin-info-card">
        <h3>Challenge completions</h3>
        <p class="admin-muted"><%= typeof completedChallenges !== 'undefined' ? completedChallenges : (challengeCompletions?.length || 0) %> submissions</p>
      </article>
    </div>
  </section>
</main>

<%- include('../partials/admin-footer') %>