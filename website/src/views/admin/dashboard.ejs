<%- include('../partials/admin-header', { title: 'Admin Dashboard' }) %>

<main class="admin-shell">
  <section class="admin-panel admin-hero">
    <div>
      <p class="admin-eyebrow">Operations overview</p>
      <h1>Admin dashboard</h1>
      <p class="admin-muted">Track lesson progress, student completion, challenge submissions, inbox activity, and admin tools in one place.</p>
    </div>
    <div class="admin-hero-stats">
      <article class="admin-stat-card">
        <span class="admin-stat-label">Active lessons</span>
        <strong><%= stats?.total_lessons || 0 %></strong>
      </article>
      <article class="admin-stat-card">
        <span class="admin-stat-label">Pending messages</span>
        <strong><%= stats?.pending_messages || 0 %></strong>
      </article>
      <article class="admin-stat-card">
        <span class="admin-stat-label">Certificates</span>
        <strong><%= stats?.issued_certs || 0 %></strong>
      </article>
    </div>
  </section>

  <section class="admin-panel">
    <div class="admin-panel-header">
      <h2>Admin tools</h2>
      <span class="admin-muted">Quick access to the same live content students see</span>
    </div>
    <div class="admin-grid admin-grid-3">
      <a class="admin-info-card admin-link" href="/admin/scripts">
        <h3>Scripts</h3>
        <p class="admin-muted"><%= stats?.total_scripts || 0 %> total · <%= stats?.public_scripts || 0 %> public</p>
      </a>
      <a class="admin-info-card admin-link" href="/admin/prompts">
        <h3>Prompts</h3>
        <p class="admin-muted">Manage student-facing prompt library</p>
      </a>
      <a class="admin-info-card admin-link" href="/admin/quizzes">
        <h3>Quizzes</h3>
        <p class="admin-muted"><%= stats?.total_quizzes || 0 %> total quiz records</p>
      </a>
      <a class="admin-info-card admin-link" href="/admin/lessons">
        <h3>Lessons</h3>
        <p class="admin-muted"><%= stats?.total_lessons || 0 %> lessons</p>
      </a>
      <a class="admin-info-card admin-link" href="/admin/session-requests">
        <h3>Sessions</h3>
        <p class="admin-muted">Approve, reject, and complete requests</p>
      </a>
      <a class="admin-info-card admin-link" href="/admin/schedules">
        <h3>Schedules</h3>
        <p class="admin-muted">Manage announcements and scheduled sessions</p>
      </a>
    </div>
  </section>

  <section class="admin-grid admin-grid-3">
    <div class="admin-panel">
      <div class="admin-panel-header">
        <h2>Recent scripts</h2>
        <a class="admin-link" href="/admin/scripts">Manage scripts</a>
      </div>
      <% if (Array.isArray(recentScripts) && recentScripts.length) { %>
        <div class="admin-list">
          <% recentScripts.forEach((script) => { %>
            <article class="admin-list-item">
              <div>
                <strong><%= script.title %></strong>
                <p class="admin-muted"><%= script.category || 'uncategorized' %> · <%= script.author || 'Admin' %></p>
              </div>
              <span class="admin-pill"><%= String(script.price_tier || 'free').toUpperCase() %></span>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <p class="admin-empty">No scripts found.</p>
      <% } %>
    </div>

    <div class="admin-panel">
    <div class="admin-panel-header">
      <h2>Recent prompts</h2>
      <a class="admin-link" href="/admin/prompts">Manage prompts</a>
    </div>
    <p class="admin-muted">Prompts are maintained from the prompt management section.</p>
  </div>

    <div class="admin-panel">
      <div class="admin-panel-header">
        <h2>Recent quizzes</h2>
        <a class="admin-link" href="/admin/quizzes">Manage quizzes</a>
      </div>
      <% if (Array.isArray(recentQuizzes) && recentQuizzes.length) { %>
        <div class="admin-list">
          <% recentQuizzes.forEach((quiz) => { %>
            <article class="admin-list-item">
              <div>
                <strong><%= quiz.title %></strong>
                <p class="admin-muted"><%= quiz.lesson_title || 'Unlinked' %> · <%= quiz.question_count ?? 0 %> questions</p>
              </div>
              <span class="admin-pill"><%= String(quiz.price_tier || 'free').toUpperCase() %></span>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <p class="admin-empty">No quizzes found.</p>
      <% } %>
    </div>
  </section>

  <section class="admin-grid admin-grid-2">
    <div class="admin-panel">
      <div class="admin-panel-header">
        <h2>Recent progress</h2>
        <a class="admin-link" href="/admin/lessons">Manage lessons</a>
      </div>
      <% if (Array.isArray(recentProgress) && recentProgress.length) { %>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Student</th>
                <th>Lesson</th>
                <th>Status</th>
                <th>Completed</th>
              </tr>
            </thead>
            <tbody>
              <% recentProgress.forEach((item) => { %>
                <tr>
                  <td><%= item.student_name || item.student || 'Student' %></td>
                  <td><%= item.lesson_title || item.lesson || 'Lesson' %></td>
                  <td><span class="admin-pill"><%= item.status || 'In progress' %></span></td>
                  <td><%= item.completed_at ? new Date(item.completed_at).toLocaleString() : '—' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <p class="admin-empty">No progress data yet.</p>
      <% } %>
    </div>

    <div class="admin-panel">
      <div class="admin-panel-header">
        <h2>Latest inbox activity</h2>
        <a class="admin-link" href="/admin/messages">Open inbox</a>
      </div>
      <% if (Array.isArray(recentMessages) && recentMessages.length) { %>
        <div class="admin-list">
          <% recentMessages.forEach((message) => { %>
            <article class="admin-list-item">
              <div>
                <strong><%= message.subject || 'No subject' %></strong>
                <p class="admin-muted"><%= message.sender_name || message.sender || 'Student' %> · <%= message.created_at ? new Date(message.created_at).toLocaleString() : '' %></p>
              </div>
              <span class="admin-pill <%= message.replied_at ? 'admin-pill-success' : 'admin-pill-warning' %>"><%= message.replied_at ? 'Replied' : 'New' %></span>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <p class="admin-empty">No inbox activity yet.</p>
      <% } %>
    </div>
  </section>

  <section class="admin-panel">
    <div class="admin-panel-header">
      <h2>Certificates & completions</h2>
      <a class="admin-link" href="/admin/certifications">Manage certificates</a>
    </div>
    <div class="admin-grid admin-grid-3">
      <article class="admin-info-card">
        <h3>Issued certificates</h3>
        <p class="admin-muted"><%= stats?.issued_certs || 0 %> total</p>
      </article>
      <article class="admin-info-card">
        <h3>Pending review</h3>
        <p class="admin-muted">0 items</p>
      </article>
      <article class="admin-info-card">
        <h3>Challenge completions</h3>
        <p class="admin-muted"><%= stats?.completed_lessons || 0 %> submissions</p>
      </article>
    </div>
  </section>
</main>

<%- include('../partials/admin-footer') %>
