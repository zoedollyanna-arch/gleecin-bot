<%- include('../partials/admin-header', { title: 'Admin Logs' }) %>

<main class="admin-shell">
  <section class="admin-panel">
    <div class="admin-panel-header">
      <div>
        <p class="admin-eyebrow">Audit trail</p>
        <h1>Logs</h1>
        <p class="admin-muted">Track all admin activity, filter actions, and review details from one unified page.</p>
      </div>
    </div>

    <div class="admin-form-grid">
      <label class="admin-field">
        <span>Filter by admin</span>
        <input type="text" id="adminFilter" placeholder="Search admin name...">
      </label>
      <label class="admin-field">
        <span>Filter by action</span>
        <select id="actionFilter">
          <option value="">All actions</option>
          <option value="make_admin">Make admin</option>
          <option value="set_tier">Set tier</option>
          <option value="verify_payment">Verify payment</option>
          <option value="reject_payment">Reject payment</option>
          <option value="upload_script">Upload script</option>
          <option value="create_lesson">Create lesson</option>
          <option value="issue_certificate">Issue certificate</option>
          <option value="approve_session">Approve session</option>
          <option value="reject_session">Reject session</option>
        </select>
      </label>
    </div>
  </section>

  <section class="admin-panel">
    <div class="admin-panel-header">
      <h2>Activity log</h2>
    </div>

    <% if (Array.isArray(logs) && logs.length) { %>
      <div class="admin-table-wrap">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Admin</th>
              <th>Action</th>
              <th>Target</th>
              <th>Timestamp</th>
              <th>Details</th>
            </tr>
          </thead>
          <tbody id="logsTableBody">
            <% logs.forEach((log) => { %>
              <tr class="log-row" data-admin="<%= (log.admin_name || '').toLowerCase() %>" data-action="<%= log.action %>">
                <td><strong><%= log.admin_name || 'Unknown' %></strong></td>
                <td><span class="admin-pill"><%= log.action.replace(/_/g, ' ') %></span></td>
                <td><%= log.target_name || 'N/A' %></td>
                <td><%= log.created_at ? new Date(log.created_at).toLocaleString() : '—' %></td>
                <td><%= log.details ? JSON.stringify(log.details) : '—' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <p class="admin-empty">No admin logs yet.</p>
    <% } %>
  </section>
</main>

<script>
  function filterLogs() {
    const adminFilter = document.getElementById('adminFilter').value.toLowerCase();
    const actionFilter = document.getElementById('actionFilter').value;
    document.querySelectorAll('.log-row').forEach((row) => {
      const admin = row.dataset.admin || '';
      const action = row.dataset.action || '';
      const matchesAdmin = admin.includes(adminFilter);
      const matchesAction = !actionFilter || action === actionFilter;
      row.style.display = matchesAdmin && matchesAction ? '' : 'none';
    });
  }

  document.getElementById('adminFilter').addEventListener('input', filterLogs);
  document.getElementById('actionFilter').addEventListener('change', filterLogs);
</script>

<%- include('../partials/admin-footer') %>
