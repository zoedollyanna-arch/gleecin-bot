<%- include('../partials/student-header', { title: 'Messages' }) %>

<main class="student-page">
  <section class="student-panel">
    <div class="student-panel__header">
      <div>
        <h1>Messages</h1>
        <p>Conversation history with instructors and support staff.</p>
      </div>
    </div>

    <div class="student-message-thread">
      <% if (Array.isArray(messages) && messages.length) { %>
        <% messages.forEach((message) => { %>
          <% const isOutgoing = message.direction === 'outgoing' || message.sender_role === 'student' || message.is_outgoing; %>
          <article class="student-message <%= isOutgoing ? 'student-message--outgoing' : 'student-message--incoming' %>">
            <div class="student-message__meta">
              <strong><%= message.sender_name || message.sender || (isOutgoing ? 'You' : 'Staff') %></strong>
              <span><%= message.created_at ? new Date(message.created_at).toLocaleString() : '' %></span>
            </div>
            <div class="student-message__body"><%= message.body || message.content || '' %></div>
          </article>
        <% }) %>
      <% } else { %>
        <div class="student-empty-state">
          <h2>No messages yet</h2>
          <p>Send a message to start a two-way conversation with your instructors or support team.</p>
        </div>
      <% } %>
    </div>

    <form class="student-message-compose" action="/student/messages" method="post">
      <label for="messageBody">New message</label>
      <textarea id="messageBody" name="body" rows="5" placeholder="Write your message here..." required></textarea>
      <button type="submit" class="btn btn-primary">Send message</button>
    </form>
  </section>
</main>

<%- include('../partials/student-footer') %>