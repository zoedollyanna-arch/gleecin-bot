<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Messages</title>
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    .student-container {
      background: linear-gradient(135deg, #0F0F14 0%, #1a1a22 100%);
      color: #EAEAEA;
      min-height: 100vh;
      padding: 20px;
    }

    .student-header {
      background: #1a1a22;
      border-bottom: 2px solid #7B61FF;
      padding: 20px;
      margin-bottom: 30px;
      border-radius: 8px;
    }

    .student-header h1 {
      color: #7B61FF;
      margin: 0;
      font-size: 2em;
    }

    .student-nav {
      display: flex;
      gap: 10px;
      margin-top: 15px;
      flex-wrap: wrap;
    }

    .student-nav a {
      background: #0F0F14;
      color: #00D1FF;
      padding: 10px 15px;
      border-radius: 6px;
      text-decoration: none;
      border: 1px solid #7B61FF;
      transition: all 0.3s;
    }

    .student-nav a:hover {
      background: #7B61FF;
      color: #0F0F14;
    }

    .messages-grid {
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 20px;
      margin-bottom: 30px;
    }

    .messages-list {
      background: #1a1a22;
      border: 2px solid #7B61FF;
      border-radius: 8px;
      padding: 25px;
      height: 600px;
      overflow-y: auto;
    }

    .messages-list h2 {
      color: #7B61FF;
      margin-top: 0;
    }

    .message-item {
      background: #0F0F14;
      border: 1px solid #7B61FF;
      border-radius: 6px;
      padding: 15px;
      margin-bottom: 10px;
      cursor: pointer;
      transition: all 0.3s;
    }

    .message-item:hover {
      background: rgba(123, 97, 255, 0.2);
    }

    .message-item.unread {
      border-left: 4px solid #FF7A00;
      font-weight: bold;
    }

    .message-item.active {
      border-left: 4px solid #00D1FF;
      background: rgba(123, 97, 255, 0.3);
    }

    .message-from {
      color: #00D1FF;
      font-weight: bold;
      margin-bottom: 3px;
    }

    .message-preview {
      color: #999;
      font-size: 0.9em;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .message-time {
      color: #666;
      font-size: 0.8em;
      margin-top: 5px;
    }

    .message-detail {
      background: #1a1a22;
      border: 2px solid #7B61FF;
      border-radius: 8px;
      padding: 25px;
    }

    .message-detail h3 {
      color: #7B61FF;
      margin-top: 0;
    }

    .message-header {
      background: #0F0F14;
      border: 1px solid #7B61FF;
      border-radius: 6px;
      padding: 15px;
      margin-bottom: 20px;
    }

    .message-header p {
      margin: 5px 0;
      color: #EAEAEA;
    }

    .message-header strong {
      color: #00D1FF;
    }

    .message-content {
      background: #0F0F14;
      border: 1px solid #7B61FF;
      border-radius: 6px;
      padding: 20px;
      margin-bottom: 20px;
      min-height: 150px;
      white-space: pre-wrap;
      word-wrap: break-word;
    }

    .compose-section {
      background: #1a1a22;
      border: 2px solid #7B61FF;
      border-radius: 8px;
      padding: 25px;
      margin-bottom: 30px;
    }

    .compose-section h2 {
      color: #7B61FF;
      margin-top: 0;
    }

    .form-group {
      margin-bottom: 15px;
    }

    .form-group label {
      display: block;
      color: #7B61FF;
      margin-bottom: 5px;
      font-weight: bold;
    }

    .form-group input,
    .form-group textarea {
      width: 100%;
      background: #0F0F14;
      border: 1px solid #7B61FF;
      color: #EAEAEA;
      padding: 12px;
      border-radius: 6px;
      font-family: inherit;
    }

    .form-group textarea {
      min-height: 120px;
      resize: vertical;
    }

    .btn {
      background: #7B61FF;
      color: white;
      padding: 10px 20px;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-weight: bold;
      margin-top: 10px;
      transition: all 0.3s;
    }

    .btn:hover {
      background: #6a4df5;
    }

    .empty-state {
      text-align: center;
      padding: 40px;
      color: #999;
    }

    .unread-badge {
      background: #FF7A00;
      color: white;
      border-radius: 50%;
      padding: 2px 6px;
      font-size: 0.8em;
      margin-left: 5px;
    }

    @media (max-width: 1024px) {
      .messages-grid {
        grid-template-columns: 1fr;
      }

      .messages-list {
        height: auto;
        max-height: 400px;
      }
    }

    @media (max-width: 768px) {
      .student-nav {
        flex-direction: column;
      }

      .student-nav a {
        width: 100%;
        text-align: center;
      }
    }
  </style>
</head>
<body>
  <div class="student-container">
    <div class="student-header">
      <h1>💬 My Messages</h1>
      <p style="margin: 10px 0 0 0; color: #999;">
        Support inbox 
        <% if (unreadCount > 0) { %>
          <span class="unread-badge"><%= unreadCount %> Unread</span>
        <% } %>
      </p>
      <div class="student-nav">
        <a href="/dashboard">📊 Dashboard</a>
        <a href="/student/sessions">📅 Sessions</a>
        <a href="/student/messages" style="background: #7B61FF; color: #0F0F14;">💬 Messages</a>
        <a href="/student/lessons">🎓 Lessons</a>
        <a href="/student/activities">💻 Activities</a>
        <a href="/student/quizzes">📝 Quizzes</a>
        <a href="/auth/logout" style="background: #ff6b6b; color: white; border: 1px solid #ff6b6b;">🚪 Logout</a>
      </div>
    </div>

    <div class="compose-section">
      <h2>Send New Message</h2>
      <form id="compose-form">
        <div class="form-group">
          <label for="subject">Subject</label>
          <input type="text" id="subject" name="subject" placeholder="Brief description of your question..." required>
        </div>
        <div class="form-group">
          <label for="content">Message</label>
          <textarea id="content" name="content" placeholder="Describe your issue or question in detail..." required></textarea>
        </div>
        <button type="submit" class="btn">Send Message</button>
      </form>
    </div>

    <div class="messages-grid">
      <div class="messages-list">
        <h2>Inbox</h2>
        
        <% if (messages && messages.length > 0) { %>
          <% messages.forEach((msg) => { %>
            <div 
              class="message-item <%= msg.is_read ? '' : 'unread' %>" 
              onclick="loadMessage(<%= msg.id %>)"
              id="msg-<%= msg.id %>"
            >
              <div class="message-from"><%= msg.sender_name %></div>
              <div class="message-preview"><%= msg.content.substring(0, 50) %>...</div>
              <div class="message-time"><%= new Date(msg.created_at).toLocaleDateString() %></div>
            </div>
          <% }); %>
        <% } else { %>
          <div class="empty-state">
            <p>📭 No messages</p>
          </div>
        <% } %>
      </div>

      <div class="message-detail" id="message-detail">
        <div style="text-align: center; color: #999; padding: 40px;">
          <p>Select a message to view details</p>
        </div>
      </div>
    </div>
  </div>

  <script>
    let messages = <%- JSON.stringify(messages) %>;

    document.getElementById('compose-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const subject = document.getElementById('subject').value;
      const content = document.getElementById('content').value;

      try {
        const res = await fetch('/student/messages/send', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ subject, content })
        });
        
        const data = await res.json();
        
        if (data.success) {
          alert('Message sent!');
          document.getElementById('compose-form').reset();
        } else {
          alert('Error: ' + data.error);
        }
      } catch (error) {
        alert('Error: ' + error.message);
      }
    });

    function loadMessage(messageId) {
      const msg = messages.find(m => m.id === messageId);
      if (!msg) return;

      const html = `
        <div>
          <h3 style="color: #7B61FF; margin-top: 0;">${msg.subject || 'Support Message'}</h3>
          
          <div class="message-header">
            <p><strong>From:</strong> ${msg.sender_name}</p>
            <p><strong>Date:</strong> ${new Date(msg.created_at).toLocaleString()}</p>
            <p><strong>Status:</strong> ${msg.is_read ? 'Read' : 'Unread'}</p>
          </div>

          <div class="message-content">${msg.content}</div>

          <button class="btn" onclick="markAsRead(${messageId})">Mark as Read</button>
        </div>
      `;

      document.getElementById('message-detail').innerHTML = html;
      
      document.querySelectorAll('.message-item').forEach(el => el.classList.remove('active'));
      document.getElementById(`msg-${messageId}`).classList.add('active');
    }

    async function markAsRead(messageId) {
      try {
        const res = await fetch(`/student/messages/${messageId}/mark-read`, { method: 'POST' });
        const data = await res.json();
        if (data.success) {
          document.getElementById(`msg-${messageId}`).classList.remove('unread');
          alert('Marked as read');
        }
      } catch (error) {
        console.error(error);
      }
    }
  </script>
</body>
</html>
