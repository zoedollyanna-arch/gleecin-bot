<%- include('../partials/student-header', { title: 'Quizzes' }) %>

<main class="student-page">
  <section class="student-panel">
    <div class="student-panel__header">
      <div>
        <h1>Quizzes</h1>
        <p>See quiz availability, progress, and completion status.</p>
      </div>
    </div>

    <% if (Array.isArray(quizzes) && quizzes.length) { %>
      <div class="student-card-grid">
        <% quizzes.forEach((quiz) => { %>
          <article class="student-card">
            <div class="student-card__topline">
              <h2><a href="<%= quiz.url || ('/student/quizzes/' + (quiz.id || '')) %>"><%= quiz.title || quiz.name || 'Quiz' %></a></h2>
              <% if (quiz.completed || quiz.is_completed || quiz.passed) { %>
                <span class="student-badge student-badge--success">Completed</span>
              <% } else if ((quiz.attempted || quiz.attempts_count || 0) > 0) { %>
                <span class="student-badge">In progress</span>
              <% } else { %>
                <span class="student-badge student-badge--muted">Not started</span>
              <% } %>
            </div>
            <p><%= quiz.description || quiz.summary || '' %></p>
            <div class="student-card__actions">
              <a class="btn btn-secondary" href="<%= quiz.url || ('/student/quizzes/' + (quiz.id || '')) %>">
                <%= quiz.completed || quiz.is_completed || quiz.passed ? 'Review quiz' : ((quiz.attempted || quiz.attempts_count || 0) > 0 ? 'Continue quiz' : 'Start quiz') %>
              </a>
            </div>
          </article>
        <% }) %>
      </div>
    <% } else { %>
      <div class="student-empty-state">
        <h2>No quizzes available</h2>
        <p>Assigned quizzes will appear here once they are published.</p>
      </div>
    <% } %>
  </section>
</main>

<%- include('../partials/student-footer') %>