<%- include('../partials/student-header', { title: 'Lesson Vault' }) %>

<main class="student-page">
  <section class="student-panel">
    <div class="student-panel__header">
      <div>
        <h1>Lesson Vault</h1>
        <p>All lessons appear here when they are available.</p>
      </div>
    </div>

    <% if (Array.isArray(lessons) && lessons.length) { %>
      <div class="student-card-grid">
        <% lessons.forEach((lesson) => { %>
          <article class="student-card">
            <div class="student-card__topline">
              <h2><a href="<%= lesson.url || ('/student/lessons/' + (lesson.id || '')) %>"><%= lesson.title || lesson.name || 'Lesson' %></a></h2>
              <% if (lesson.completed || lesson.is_completed) { %>
                <span class="student-badge student-badge--success">Completed</span>
              <% } else if (lesson.progress != null || lesson.progress_percent != null) { %>
                <span class="student-badge">In progress</span>
              <% } else { %>
                <span class="student-badge student-badge--muted">Available</span>
              <% } %>
            </div>
            <p><%= lesson.description || lesson.summary || '' %></p>
          </article>
        <% }) %>
      </div>
    <% } else { %>
      <div class="student-empty-state">
        <h2>Lesson vault is empty</h2>
        <p>Lessons will appear here by default once they are assigned to your class.</p>
      </div>
    <% } %>
  </section>

  <section class="student-panel">
    <div class="student-panel__header">
      <div>
        <h2>Certificates</h2>
        <p>Your earned certificates will be shown here when available.</p>
      </div>
    </div>

    <% if (Array.isArray(certificates) && certificates.length) { %>
      <div class="student-card-grid">
        <% certificates.forEach((certificate) => { %>
          <article class="student-card">
            <h3><%= certificate.title || certificate.name || 'Certificate' %></h3>
            <p><%= certificate.description || certificate.summary || '' %></p>
            <% if (certificate.url || certificate.download_url) { %>
              <a class="btn btn-secondary" href="<%= certificate.url || certificate.download_url %>">View certificate</a>
            <% } %>
          </article>
        <% }) %>
      </div>
    <% } else { %>
      <div class="student-empty-state">
        <h3>No certificates yet</h3>
        <p>Certificates will appear here after you complete the required learning milestones.</p>
      </div>
    <% } %>
  </section>

  <section class="student-panel">
    <div class="student-panel__header">
      <div>
        <h2>Reviews</h2>
        <p>Recent student reviews and feedback.</p>
      </div>
    </div>

    <% if (Array.isArray(reviews) && reviews.length) { %>
      <div class="student-review-list">
        <% reviews.forEach((review) => { %>
          <article class="student-review">
            <strong><%= review.user_name || review.author || 'Student' %></strong>
            <p><%= review.content || review.body || '' %></p>
          </article>
        <% }) %>
      </div>
    <% } else { %>
      <div class="student-empty-state">
        <h3>Be the first to write a review</h3>
        <p>No reviews have been posted yet.</p>
      </div>
    <% } %>
  </section>
</main>

<%- include('../partials/student-footer') %>