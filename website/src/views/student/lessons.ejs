<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Lesson Vault</title>
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    .student-container {
      background: linear-gradient(135deg, #0F0F14 0%, #1a1a22 100%);
      color: #EAEAEA;
      min-height: 100vh;
      padding: 20px;
    }

    .student-header {
      background: #1a1a22;
      border-bottom: 2px solid #7B61FF;
      padding: 20px;
      margin-bottom: 30px;
      border-radius: 8px;
    }

    .student-header h1 {
      color: #7B61FF;
      margin: 0;
      font-size: 2em;
    }

    .student-nav {
      display: flex;
      gap: 10px;
      margin-top: 15px;
      flex-wrap: wrap;
    }

    .student-nav a {
      background: #0F0F14;
      color: #00D1FF;
      padding: 10px 15px;
      border-radius: 6px;
      text-decoration: none;
      border: 1px solid #7B61FF;
      transition: all 0.3s;
    }

    .student-nav a:hover {
      background: #7B61FF;
      color: #0F0F14;
    }

    .content-section {
      background: #1a1a22;
      border: 2px solid #7B61FF;
      border-radius: 8px;
      padding: 25px;
      margin-bottom: 30px;
    }

    .content-section h2 {
      color: #7B61FF;
      margin-top: 0;
    }

    .lessons-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 20px;
      margin-top: 20px;
    }

    .lesson-card {
      background: #0F0F14;
      border: 1px solid #7B61FF;
      border-radius: 8px;
      padding: 20px;
      transition: all 0.3s;
    }

    .lesson-card:hover {
      border-color: #00D1FF;
      transform: translateY(-5px);
    }

    .lesson-title {
      color: #00D1FF;
      font-size: 1.2em;
      font-weight: bold;
      margin: 0 0 10px 0;
    }

    .lesson-meta {
      display: flex;
      gap: 10px;
      margin-bottom: 10px;
      font-size: 0.85em;
      color: #999;
    }

    .tier-badge {
      background: rgba(123, 97, 255, 0.2);
      color: #7B61FF;
      padding: 2px 8px;
      border-radius: 4px;
    }

    .progress-bar {
      background: rgba(123, 97, 255, 0.2);
      height: 6px;
      border-radius: 3px;
      margin: 10px 0;
      overflow: hidden;
    }

    .progress-fill {
      background: #7B61FF;
      height: 100%;
      transition: width 0.3s;
    }

    .btn {
      background: #7B61FF;
      color: white;
      padding: 8px 16px;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-weight: bold;
      text-decoration: none;
      display: inline-block;
      transition: all 0.3s;
    }

    .btn:hover {
      background: #6a4df5;
    }

    .empty-state {
      text-align: center;
      padding: 40px;
      color: #999;
    }

    @media (max-width: 768px) {
      .student-nav {
        flex-direction: column;
      }

      .student-nav a {
        width: 100%;
        text-align: center;
      }

      .lessons-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <div class="student-container">
    <div class="student-header">
      <h1>🎓 Lesson Vault</h1>
      <p style="margin: 10px 0 0 0; color: #999;">Access video lessons and tutorials</p>
      <div class="student-nav">
        <a href="/dashboard">📊 Dashboard</a>
        <a href="/student/sessions">📅 Sessions</a>
        <a href="/student/messages">💬 Messages</a>
        <a href="/student/lessons" style="background: #7B61FF; color: #0F0F14;">🎓 Lessons</a>
        <a href="/student/activities">💻 Activities</a>
        <a href="/student/quizzes">📝 Quizzes</a>
        <a href="/auth/logout" style="background: #ff6b6b; color: white; border: 1px solid #ff6b6b;">🚪 Logout</a>
      </div>
    </div>

    <div class="content-section">
      <h2>Available Lessons</h2>
      
      <% if (lessons && lessons.length > 0) { %>
        <div class="lessons-grid">
          <% lessons.forEach(lesson => { %>
            <div class="lesson-card">
              <h3 class="lesson-title"><%= lesson.title %></h3>
              <div class="lesson-meta">
                <span class="tier-badge"><%= lesson.price_tier.toUpperCase() %></span>
                <span><%= lesson.level %></span>
                <span><%= lesson.duration %></span>
              </div>
              
              <% if (progressMap[lesson.id]) { %>
                <div class="progress-bar">
                  <div class="progress-fill" style="width: <%= progressMap[lesson.id].completed ? '100' : Math.min(progressMap[lesson.id].watch_time_seconds / (lesson.duration * 60) * 100, 100) %>%"></div>
                </div>
                <small style="color: #999;"><%= progressMap[lesson.id].completed ? 'Completed' : 'In progress' %></small>
              <% } %>
              
              <div style="margin-top: 15px;">
                <a href="/student/lessons/<%= lesson.id %>" class="btn">Watch Lesson</a>
              </div>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <div class="empty-state">
          <p>📭 No lessons available yet!</p>
          <p>Check back later for new content.</p>
        </div>
      <% } %>
    </div>
  </div>
</body>
</html>
