<%- include('../partials/student-header', { title: 'Activities' }) %>

<main class="student-page">
  <section class="student-panel">
    <div class="student-panel__header">
      <div>
        <h1>Activities</h1>
        <p>Track activity progress and completion status.</p>
      </div>
    </div>

    <% if (Array.isArray(activities) && activities.length) { %>
      <div class="student-card-grid">
        <% activities.forEach((activity) => { %>
          <article class="student-card">
            <div class="student-card__topline">
              <h2><a href="<%= activity.url || ('/student/activities/' + (activity.id || '')) %>"><%= activity.title || activity.name || 'Activity' %></a></h2>
              <% if (activity.completed || activity.is_completed) { %>
                <span class="student-badge student-badge--success">Completed</span>
              <% } else if (activity.progress != null || activity.progress_percent != null) { %>
                <span class="student-badge">In progress</span>
              <% } else { %>
                <span class="student-badge student-badge--muted">Not started</span>
              <% } %>
            </div>
            <p><%= activity.description || activity.summary || '' %></p>
            <% const progressValue = activity.progress_percent != null ? activity.progress_percent : activity.progress; %>
            <% if (progressValue != null) { %>
              <div class="student-progress">
                <div class="student-progress__bar">
                  <span style="width: <%= Math.max(0, Math.min(100, Number(progressValue) || 0)) %>%"></span>
                </div>
                <small><%= Number(progressValue) || 0 %>% complete</small>
              </div>
            <% } %>
          </article>
        <% }) %>
      </div>
    <% } else { %>
      <div class="student-empty-state">
        <h2>No activities available</h2>
        <p>Once activities are assigned, they will appear here with progress and completion updates.</p>
      </div>
    <% } %>
  </section>
</main>

<%- include('../partials/student-footer') %>