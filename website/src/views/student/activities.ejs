<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Coding Activities</title>
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    .student-container {
      background: linear-gradient(135deg, #0F0F14 0%, #1a1a22 100%);
      color: #EAEAEA;
      min-height: 100vh;
      padding: 20px;
    }

    .student-header {
      background: #1a1a22;
      border-bottom: 2px solid #7B61FF;
      padding: 20px;
      margin-bottom: 30px;
      border-radius: 8px;
    }

    .student-header h1 {
      color: #7B61FF;
      margin: 0;
      font-size: 2em;
    }

    .student-nav {
      display: flex;
      gap: 10px;
      margin-top: 15px;
      flex-wrap: wrap;
    }

    .student-nav a {
      background: #0F0F14;
      color: #00D1FF;
      padding: 10px 15px;
      border-radius: 6px;
      text-decoration: none;
      border: 1px solid #7B61FF;
      transition: all 0.3s;
    }

    .student-nav a:hover {
      background: #7B61FF;
      color: #0F0F14;
    }

    .content-section {
      background: #1a1a22;
      border: 2px solid #7B61FF;
      border-radius: 8px;
      padding: 25px;
      margin-bottom: 30px;
    }

    .content-section h2 {
      color: #7B61FF;
      margin-top: 0;
    }

    .activities-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
      gap: 20px;
      margin-top: 20px;
    }

    .activity-card {
      background: #0F0F14;
      border: 1px solid #7B61FF;
      border-radius: 8px;
      padding: 20px;
      transition: all 0.3s;
    }

    .activity-card:hover {
      border-color: #00D1FF;
      transform: translateY(-5px);
    }

    .activity-title {
      color: #00D1FF;
      font-size: 1.2em;
      font-weight: bold;
      margin: 0 0 10px 0;
    }

    .activity-meta {
      display: flex;
      gap: 10px;
      margin-bottom: 10px;
      font-size: 0.85em;
      color: #999;
    }

    .difficulty-badge {
      background: rgba(123, 97, 255, 0.2);
      color: #7B61FF;
      padding: 2px 8px;
      border-radius: 4px;
    }

    .status-badge {
      display: inline-block;
      padding: 4px 8px;
      border-radius: 4px;
      font-size: 0.8em;
      font-weight: bold;
    }

    .status-pending {
      background: rgba(255, 122, 0, 0.2);
      color: #FF7A00;
    }

    .status-submitted {
      background: rgba(0, 209, 255, 0.2);
      color: #00D1FF;
    }

    .status-approved {
      background: rgba(76, 175, 80, 0.2);
      color: #4CAF50;
    }

    .activity-description {
      color: #EAEAEA;
      margin: 10px 0;
      font-size: 0.9em;
    }

    .btn {
      background: #7B61FF;
      color: white;
      padding: 8px 16px;
      border: none;
      border-radius: 4px;
      cursor: pointer;
      font-weight: bold;
      text-decoration: none;
      display: inline-block;
      transition: all 0.3s;
    }

    .btn:hover {
      background: #6a4df5;
    }

    .empty-state {
      text-align: center;
      padding: 40px;
      color: #999;
    }

    @media (max-width: 768px) {
      .student-nav {
        flex-direction: column;
      }

      .student-nav a {
        width: 100%;
        text-align: center;
      }

      .activities-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <div class="student-container">
    <div class="student-header">
      <h1>💻 Coding Activities</h1>
      <p style="margin: 10px 0 0 0; color: #999;">Hands-on scripting challenges and exercises</p>
      <div class="student-nav">
        <a href="/dashboard">📊 Dashboard</a>
        <a href="/student/sessions">📅 Sessions</a>
        <a href="/student/messages">💬 Messages</a>
        <a href="/student/lessons">🎓 Lessons</a>
        <a href="/student/activities" style="background: #7B61FF; color: #0F0F14;">💻 Activities</a>
        <a href="/student/quizzes">📝 Quizzes</a>
        <a href="/auth/logout" style="background: #ff6b6b; color: white; border: 1px solid #ff6b6b;">🚪 Logout</a>
      </div>
    </div>

    <div class="content-section">
      <h2>Available Activities</h2>
      
      <% if (activities && activities.length > 0) { %>
        <div class="activities-grid">
          <% activities.forEach(activity => { %>
            <div class="activity-card">
              <h3 class="activity-title"><%= activity.title %></h3>
              <div class="activity-meta">
                <span class="difficulty-badge"><%= activity.difficulty %></span>
                <span class="tier-badge"><%= activity.price_tier.toUpperCase() %></span>
              </div>
              
              <p class="activity-description"><%= activity.description %></p>
              
              <% if (submissionMap[activity.id]) { %>
                <div style="margin-top: 10px;">
                  <span class="status-badge status-<%= submissionMap[activity.id].status %>">
                    <%= submissionMap[activity.id].status.toUpperCase() %>
                  </span>
                </div>
              <% } %>
              
              <div style="margin-top: 15px;">
                <a class="btn" href="/learning?activity=<%= activity.id %>">
                  <%= submissionMap[activity.id] ? 'View Submission' : 'Start Activity' %>
                </a>
              </div>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <div class="empty-state">
          <p>📭 No activities available yet!</p>
          <p>Check back later for new coding challenges.</p>
        </div>
      <% } %>
    </div>
  </div>

  <script>
    // Activities route to /learning with the selected activity id.
  </script>
</body>
</html>
