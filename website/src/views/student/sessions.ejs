<%- include('../partials/student-header', { title: 'My Sessions' }) %>

<main class="student-page">
  <section class="student-panel">
    <div class="student-panel__header">
      <div>
        <p class="admin-eyebrow">Session scheduling</p>
        <h1>My sessions</h1>
        <p>Request a session, review your schedule, and see updates as they are approved.</p>
      </div>
    </div>

    <div class="student-grid student-grid-2">
      <form id="session-form" class="student-form">
        <h2>Request a new session</h2>
        <label class="student-field">
          <span>Session title</span>
          <input type="text" id="title" name="title" placeholder="e.g. Help with movement scripts" required>
        </label>
        <label class="student-field">
          <span>Preferred date and time</span>
          <input type="datetime-local" id="requested_date" name="requested_date">
        </label>
        <label class="student-field">
          <span>Description</span>
          <textarea id="description" name="description" rows="5" placeholder="Describe what you'd like help with..." required></textarea>
        </label>
        <div class="student-form-actions">
          <button type="submit" class="admin-btn admin-btn-primary">Submit request</button>
        </div>
      </form>

      <div class="admin-info-card">
        <h2>Upcoming updates</h2>
        <% if (Array.isArray(sessions) && sessions.length) { %>
          <div class="admin-list">
            <% sessions.slice(0, 3).forEach((session) => { %>
              <article class="admin-list-item">
                <div>
                  <strong><%= session.topic || session.title || 'Session' %></strong>
                  <p class="admin-muted"><%= session.status || 'pending' %> · <%= session.admin_name || 'Admin review' %></p>
                </div>
                <span class="admin-pill"><%= session.scheduled_at ? new Date(session.scheduled_at).toLocaleString() : 'Unscheduled' %></span>
              </article>
            <% }) %>
          </div>
        <% } else { %>
          <p class="admin-empty">No sessions yet.</p>
        <% } %>
      </div>
    </div>
  </section>

  <section class="student-panel">
    <div class="student-panel__header">
      <div>
        <h2>My session history</h2>
        <p>Current requests and scheduled sessions appear here once saved by admin.</p>
      </div>
    </div>

    <% if (Array.isArray(sessions) && sessions.length) { %>
      <div class="student-list">
        <% sessions.forEach((session) => { %>
          <article class="student-card">
            <div class="student-card__topline">
              <div>
                <h3><%= session.topic || session.title || 'Session' %></h3>
                <p><%= session.description || 'No description provided.' %></p>
              </div>
              <span class="student-badge"><%= String(session.status || 'pending').toUpperCase() %></span>
            </div>
            <div class="student-meta">
              <span>Requested <%= session.created_at ? new Date(session.created_at).toLocaleString() : '—' %></span>
              <span>Scheduled <%= session.scheduled_at ? new Date(session.scheduled_at).toLocaleString() : 'Pending' %></span>
              <span>Admin <%= session.admin_name || 'Not assigned' %></span>
            </div>
            <% if (session.admin_notes) { %>
              <p class="student-note"><strong>Notes:</strong> <%= session.admin_notes %></p>
            <% } %>
          </article>
        <% }) %>
      </div>
    <% } else { %>
      <div class="student-empty-state">No session requests yet.</div>
    <% } %>
  </section>
</main>

<script>
  document.getElementById('session-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const payload = Object.fromEntries(new FormData(e.target));
    const res = await fetch('/student/sessions/request', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    });
    const data = await res.json();
    if (data.success) {
      window.location.reload();
    } else {
      alert(data.error || 'Failed to submit session request');
    }
  });
</script>

<%- include('../partials/student-footer') %>
