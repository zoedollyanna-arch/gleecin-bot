<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'Page' %></title>
    <style>
        :root {
            --primary: #7B61FF;
            --dark: #0F0F14;
            --light: #EAEAEA;
            --border: #2A2A35;
            --card-bg: #1A1A22;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { background-color: var(--dark); color: var(--light); font-family: sans-serif; }
        
        header {
            background: rgba(15, 15, 20, 0.9);
            padding: 1rem 2rem;
            border-bottom: 2px solid var(--primary);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo { color: var(--primary); font-weight: bold; font-size: 1.5rem; }

        nav a {
            color: var(--light);
            text-decoration: none;
            margin-left: 2rem;
            padding: 0.5rem 0.75rem;
            border-radius: 6px;
            transition: all 0.2s ease;
        }

        nav a:hover { 
            color: var(--primary); 
            background: rgba(123, 97, 255, 0.1);
        }

        .container {
            max-width: 1200px;
            margin: 2rem auto;
            padding: 0 2rem;
        }

        h1 { color: var(--primary); margin-bottom: 2rem; font-size: 2.5rem; }

        .placeholder {
            background: var(--card-bg);
            border: 2px dashed var(--border);
            padding: 3rem 2rem;
            text-align: center;
            border-radius: 12px;
            color: #AAAAAA;
        }

        footer {
            background: rgba(15, 15, 20, 0.9);
            padding: 2rem;
            text-align: center;
            border-top: 2px solid var(--border);
            margin-top: 3rem;
        }
    </style>
</head>
<body>
    <header>
        <div class="logo">🎓 GLEECIN</div>
        <nav>
            <a href="/">Home</a>
            <a href="/academy">Academy</a>
            <a href="/scripts">Scripts</a>
            <% if (typeof isAuth !== 'undefined' && isAuth) { %><a href="/dashboard">Dashboard</a><% } %>
        </nav>
    </header>

    <div class="container">
        <h1><%= typeof title !== 'undefined' ? title : 'Page' %></h1>
        <div class="placeholder">
            <p>This page is currently under development.</p>
            <p style="margin-top: 1rem;">Check back soon for exciting content!</p>
        </div>
    </div>

    <footer>
        <p>&copy; 2026 GLEECIN Academy</p>
    </footer>
</body>
</html>