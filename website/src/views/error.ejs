<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <title><%= typeof title !== 'undefined' ? title : 'Error' %></title>
    <style>
        .error-page {
            min-height: 100vh;
            display: grid;
            place-items: center;
            padding: 2rem;
        }

        .error-card {
            width: min(720px, 100%);
            background: var(--card-background);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 2rem;
            text-align: center;
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.35);
        }

        .error-card h1 {
            color: var(--accent-violet);
            margin-bottom: 0.75rem;
            font-size: 2.2rem;
        }

        .error-card p {
            color: var(--text-color);
            line-height: 1.6;
            margin-bottom: 1rem;
        }

        .error-actions {
            display: flex;
            gap: 0.75rem;
            justify-content: center;
            flex-wrap: wrap;
            margin-top: 1.5rem;
        }
    </style>
</head>
<body>
    <%- include('partials/header') %>
    <main class="error-page">
        <section class="error-card">
            <h1>Something went wrong</h1>
            <p><%= typeof error !== 'undefined' ? error : 'The requested page could not be loaded.' %></p>
            <p>This route is now handled by a production error page instead of a placeholder.</p>
            <div class="error-actions">
                <a href="/" class="btn btn-primary">Home</a>
                <a href="/dashboard" class="btn btn-secondary">Dashboard</a>
                <a href="/scripts" class="btn btn-secondary">Script Library</a>
            </div>
        </section>
    </main>
    <%- include('partials/footer') %>
</body>
</html>
