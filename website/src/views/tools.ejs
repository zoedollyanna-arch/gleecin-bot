<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head'); %>
    <title>Tools & Setup | GLEECIN Academy</title>
    <link rel="stylesheet" href="/css/tools.css">
</head>
<body class="tools-page">
    <%- include('partials/header'); %>
    
    <main class="tools-container">
        <div class="tools-header">
            <h1>Development Tools & Setup Guides</h1>
            <p>Everything you need to get started with development in virtual worlds.</p>
        </div>

        <div class="tools-categories">
            <div class="category">
                <h2>Essential Tools</h2>
                <div class="tool-cards">
                    <div class="tool-card">
                        <h3>Virtual World Client</h3>
                        <p>Download and install the official client for your platform.</p>
                        <a href="#" class="btn-secondary">Download Guide</a>
                    </div>
                    <div class="tool-card">
                        <h3>Code Editor</h3>
                        <p>Recommended code editors with syntax highlighting for LSL.</p>
                        <a href="#" class="btn-secondary">Editor Setup</a>
                    </div>
                    <div class="tool-card">
                        <h3>Debug Console</h3>
                        <p>Learn how to use the built-in debug console for troubleshooting.</p>
                        <a href="#" class="btn-secondary">Console Guide</a>
                    </div>
                </div>
            </div>

            <div class="category">
                <h2>Advanced Tools</h2>
                <div class="tool-cards">
                    <div class="tool-card">
                        <h3>Performance Profiler</h3>
                        <p>Monitor and optimize your script performance.</p>
                        <a href="#" class="btn-secondary">Profiler Setup</a>
                    </div>
                    <div class="tool-card">
                        <h3>Version Control</h3>
                        <p>Set up Git for managing your script versions.</p>
                        <a href="#" class="btn-secondary">Git Guide</a>
                    </div>
                    <div class="tool-card">
                        <h3>Testing Framework</h3>
                        <p>Automated testing tools for your scripts.</p>
                        <a href="#" class="btn-secondary">Testing Setup</a>
                    </div>
                </div>
            </div>

            <div class="category">
                <h2>Setup Guides</h2>
                <div class="setup-guides">
                    <div class="guide">
                        <h3>Windows Setup</h3>
                        <p>Complete setup guide for Windows users.</p>
                        <a href="#" class="btn-primary">View Guide</a>
                    </div>
                    <div class="guide">
                        <h3>MacOS Setup</h3>
                        <p>Complete setup guide for Mac users.</p>
                        <a href="#" class="btn-primary">View Guide</a>
                    </div>
                    <div class="guide">
                        <h3>Linux Setup</h3>
                        <p>Complete setup guide for Linux users.</p>
                        <a href="#" class="btn-primary">View Guide</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="quick-setup">
            <h2>Quick Start Checklist</h2>
            <ol>
                <li>✅ Install Virtual World Client</li>
                <li>✅ Create Developer Account</li>
                <li>✅ Set Up Code Editor</li>
                <li>✅ Join GLEECIN Academy Group</li>
                <li>✅ Complete First Tutorial</li>
            </ol>
            <button class="btn-primary">Start Learning</button>
        </div>
    </main>

    <%- include('partials/footer'); %>
    
    <script src="/js/tools.js"></script>
</body>
</html>