<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
    <title><%= title %></title>
    <style>
        .welcome-section {
            background: rgba(123, 97, 255, 0.05);
            border: 1px solid var(--border-color);
            padding: 2rem;
            border-radius: 12px;
            margin-bottom: 2rem;
        }

        .welcome-section h1 {
            color: var(--accent-violet);
            margin-bottom: 0.5rem;
        }

        .tier-badge {
            display: inline-block;
            padding: 0.5rem 1rem;
            border-radius: 4px;
            margin: 1rem 0;
            font-weight: bold;
            font-size: 0.9rem;
        }

        .tier-free {
            background: rgba(170, 170, 170, 0.3);
            color: var(--muted-text);
        }

        .tier-paid {
            background: rgba(0, 209, 255, 0.3);
            color: var(--accent-cyan);
        }

        .tier-advanced {
            background: rgba(255, 122, 0, 0.3);
            color: var(--accent-orange);
        }

        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 2rem;
            margin-bottom: 3rem;
        }

        .card h3 {
            color: var(--accent-violet);
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .card-btn {
            display: inline-block;
            margin-top: 1rem;
        }

        .section-title {
            color: var(--accent-violet);
            font-size: 1.5rem;
            margin: 2rem 0 1rem 0;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 1rem;
        }

        .progress-item {
            background: var(--card-background);
            padding: 1rem;
            margin-bottom: 1rem;
            border-radius: 8px;
            border-left: 4px solid var(--accent-violet);
        }

        .progress-item strong {
            color: var(--text-color);
        }

        .progress-fill {
            background: var(--accent-violet);
            box-shadow: 0 0 10px var(--accent-violet);
        }
    </style>
</head>
<body>
    <%- include('partials/header') %>

    <div class="container">
    <% if (previewMode) { %>
        <div class="welcome-section" style="border-color: rgba(0, 209, 255, 0.7); background: rgba(0, 209, 255, 0.08);">
            <h1>Student preview mode</h1>
            <p>You are viewing the student dashboard layout while signed in as an admin. Use this to compare what students see against the admin dashboard.</p>
            <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1rem;">
                <a href="/dashboard" class="btn btn-primary">Back to admin view</a>
                <a href="/admin" class="btn btn-secondary">Open admin dashboard</a>
            </div>
        </div>
    <% } %>

    <div class="welcome-section">
        <h1>Welcome back, <%= user.username %></h1>
        <p>Your learning workspace is ready. Continue with classes, lessons, challenges, quizzes, and support.</p>
        <div class="tier-badge tier-<%= tier %>">
            Tier: <strong><%= tier.toUpperCase() %></strong>
        </div>
    </div>

        <div class="dashboard-grid">
            <div class="card">
                <h3>Enrolled classes</h3>
                <p>Manage your active classes and syllabus access.</p>
                <ul style="list-style: none; margin: 1rem 0; padding: 0;">
                    <li>View enrolled classes</li>
                    <li>Request enrollment from class detail pages</li>
                    <li>Open live lesson content and schedules</li>
                </ul>
                <a href="/classes" class="btn btn-primary card-btn">View classes</a>
            </div>

            <div class="card">
                <h3>Lessons</h3>
                <p>Access recorded classes and tutorials.</p>
                <p style="font-size: 0.9rem; color: #aaa;">Tier-based lesson access</p>
                <a href="/lessons" class="btn btn-primary card-btn">Watch lessons</a>
            </div>

            <div class="card">
                <h3>Challenges</h3>
                <p>Practice with interactive coding challenges.</p>
                <p style="font-size: 0.9rem; color: #aaa;">Real challenge editor with test submission</p>
                <a href="/learning" class="btn btn-primary card-btn">Start challenges</a>
            </div>

            <div class="card">
                <h3>Quizzes</h3>
                <p>Review interactive quizzes tied to your learning progress.</p>
                <p style="font-size: 0.9rem; color: #aaa;">Assignments and attempts stay in sync</p>
                <a href="/student/quizzes" class="btn btn-primary card-btn">Open quizzes</a>
            </div>

            <div class="card">
                <h3>Inbox</h3>
                <p>Read support messages and message staff.</p>
                <p style="font-size: 0.9rem; color: #aaa;">Direct access to student inbox</p>
                <a href="/student/messages" class="btn btn-primary card-btn">Open inbox</a>
            </div>

            <div class="card">
                <h3>Schedule</h3>
                <p>View upcoming classes and announcements.</p>
                <p style="font-size: 0.9rem; color: #aaa;">Live schedule and event actions</p>
                <a href="/schedule" class="btn btn-primary card-btn">View schedule</a>
            </div>

            <div class="card">
                <h3>Certificates</h3>
                <p>Track earned certificates and completion milestones.</p>
                <p style="font-size: 0.9rem; color: #aaa;">Production certificate workflow</p>
                <a href="/certification" class="btn btn-primary card-btn">View progress</a>
            </div>
        </div>

        <h2 class="section-title">Student overview</h2>
        <div class="progress-item">
            <div>
                <strong>Classes</strong>
                <span style="float: right; color: var(--accent-cyan);">Live</span>
            </div>
            <div class="progress-bar">
                <div class="progress-fill" style="width: 100%"></div>
            </div>
        </div>

        <div class="progress-item">
            <div>
                <strong>Lessons</strong>
                <span style="float: right; color: var(--accent-cyan);">Available</span>
            </div>
            <div class="progress-bar">
                <div class="progress-fill" style="width: 100%"></div>
            </div>
        </div>

        <div class="progress-item">
            <div>
                <strong>Challenges</strong>
                <span style="float: right; color: var(--accent-cyan);">Interactive</span>
            </div>
            <div class="progress-bar">
                <div class="progress-fill" style="width: 100%"></div>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>
</body>
</html>
