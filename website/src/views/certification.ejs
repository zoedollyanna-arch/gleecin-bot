<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head'); %>
    <title>Certifications | GLEECIN Academy</title>
    <link rel="stylesheet" href="/css/certification.css">
</head>
<body class="certification-page">
    <%- include('partials/header'); %>
    
    <main class="certification-container">
        <div class="certification-header">
            <h1>Your Certifications</h1>
            <p>Certificates appear here only when they have been issued by the system.</p>
        </div>

        <div class="certification-stats">
            <div class="stat-card">
                <h3 id="total-certificates">0</h3>
                <p>Total Certificates</p>
            </div>
            <div class="stat-card">
                <h3 id="verified-certificates">0</h3>
                <p>Verified</p>
            </div>
            <div class="stat-card">
                <h3 id="shared-certificates">0</h3>
                <p>Shared Publicly</p>
            </div>
        </div>

        <div id="certificates-container" class="certificates-grid"></div>

        <div id="certificates-empty-state" class="student-empty-state" style="display: none;">
            <p>No certificates earned yet.</p>
        </div>
    </main>

    <%- include('partials/footer'); %>
    
    <script src="/js/certification.js"></script>
</body>
</html>
