<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head'); %>
    <title>My Profile | GLEECIN Academy</title>
    <link rel="stylesheet" href="/css/profile.css">
</head>
<body class="profile-page">
    <%- include('partials/header'); %>
    
    <main class="profile-container">
        <div class="profile-header">
            <div class="profile-avatar">
                <% if (user.avatar_url) { %>
                    <img src="<%= user.avatar_url %>" alt="<%= user.username %>" class="profile-avatar-image">
                <% } else { %>
                    <div class="profile-avatar-placeholder"><%= (user.username || 'U').charAt(0).toUpperCase() %></div>
                <% } %>
            </div>
            <div class="profile-info">
                <h1><%= user.username || 'Member' %></h1>
                <% const userTier = user.tier || 'free'; %>
                <p class="user-tier <%= userTier %>"><%= userTier.charAt(0).toUpperCase() + userTier.slice(1) %> Member</p>
                <p class="join-date">
                    <% if (user.joined_at) { %>
                        Member since <%= new Date(user.joined_at).toLocaleDateString() %>
                    <% } else { %>
                        Member since recently
                    <% } %>
                </p>
            </div>
        </div>

        <div class="profile-tabs">
            <button class="tab active" data-tab="overview">Overview</button>
            <button class="tab" data-tab="progress">Progress</button>
            <button class="tab" data-tab="certificates">Certificates</button>
            <button class="tab" data-tab="scripts">My Scripts</button>
            <button class="tab" data-tab="settings">Settings</button>
        </div>

        <div class="tab-content active" id="overview-tab">
            <div class="stats-grid">
                <div class="stat-card">
                    <h3 id="total-lessons"><%= stats.lessonsCompleted %></h3>
                    <p>Lessons Completed</p>
                </div>
                <div class="stat-card">
                    <h3 id="total-challenges"><%= stats.challengesSolved %></h3>
                    <p>Challenges Solved</p>
                </div>
                <div class="stat-card">
                    <h3 id="total-certificates"><%= stats.certificatesEarned %></h3>
                    <p>Certificates Earned</p>
                </div>
                <div class="stat-card">
                    <h3 id="total-scripts"><%= stats.scriptsDownloaded %></h3>
                    <p>Scripts Shared</p>
                </div>
            </div>

            <div class="recent-activity">
                <h2>Recent Activity</h2>
                <div class="activity-list" id="activity-list">
                    <% if (Array.isArray(recentActivity) && recentActivity.length) { %>
                        <% recentActivity.forEach((activity) => { %>
                            <div class="activity-item">
                                <span class="activity-icon"><%= activity.activity_type === 'lesson' ? '🎓' : activity.activity_type === 'challenge' ? '✅' : '📜' %></span>
                                <div class="activity-details">
                                    <p><%= activity.title %></p>
                                    <span class="activity-time"><%= activity.created_at ? new Date(activity.created_at).toLocaleString() : 'Recently' %></span>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="student-empty-state">
                            <p>No recent activity yet. Complete lessons, challenges, or downloads to build your activity feed.</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>

        <div class="tab-content" id="progress-tab" style="display: none;">
            <h2>Learning Progress</h2>
            <div class="progress-overview">
                <div class="progress-item">
                    <div class="progress-info">
                        <h3>Scripting Fundamentals</h3>
                        <p>Course Progress</p>
                    </div>
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: 75%;"></div>
                        <span class="progress-text">75%</span>
                    </div>
                </div>
                
                <div class="progress-item">
                    <div class="progress-info">
                        <h3>Interactive Challenges</h3>
                        <p>Challenges Completed</p>
                    </div>
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: 45%;"></div>
                        <span class="progress-text">45%</span>
                    </div>
                </div>
                
                <div class="progress-item">
                    <div class="progress-info">
                        <h3>Lesson Vault</h3>
                        <p>Videos Watched</p>
                    </div>
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: 60%;"></div>
                        <span class="progress-text">60%</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-content" id="certificates-tab" style="display: none;">
            <h2>My Certificates</h2>
                <div class="certificates-grid" id="my-certificates">
                    <% if (stats.certificatesEarned > 0) { %>
                        <div class="certificate-card">
                            <div class="certificate-preview">
                                <div class="certificate-preview-placeholder">GL</div>
                            </div>
                            <div class="certificate-info">
                                <h3>Earned certificates</h3>
                                <p class="issue-date"><%= stats.certificatesEarned %> certificate<%= stats.certificatesEarned === 1 ? '' : 's' %> earned</p>
                                <div class="certificate-actions">
                                    <a class="btn-secondary" href="/certification">View certificates</a>
                                </div>
                            </div>
                        </div>
                    <% } else { %>
                        <div class="student-empty-state">
                            <p>No certificates earned yet. Complete lessons and quizzes to unlock them.</p>
                        </div>
                    <% } %>
                </div>
        </div>

        <div class="tab-content" id="scripts-tab" style="display: none;">
            <h2>My Scripts</h2>
            <div class="scripts-actions">
                <button class="btn-primary" id="upload-script">Upload New Script</button>
            </div>
                <div class="my-scripts-grid" id="my-scripts">
                    <% if (stats.scriptsDownloaded > 0) { %>
                        <div class="script-card">
                            <div class="script-header">
                                <h3>Downloaded scripts</h3>
                                <div class="script-meta">
                                    <span class="language-badge lsl">LSL</span>
                                    <span class="tag beginner">Library</span>
                                </div>
                            </div>
                            <p class="script-description">You have downloaded <%= stats.scriptsDownloaded %> script<%= stats.scriptsDownloaded === 1 ? '' : 's' %> from the library.</p>
                            <div class="script-actions">
                                <a class="btn-secondary" href="/scripts">Browse library</a>
                            </div>
                        </div>
                    <% } else { %>
                        <div class="student-empty-state">
                            <p>No scripts downloaded yet. Explore the script library to add your first one.</p>
                        </div>
                    <% } %>
                </div>
        </div>

        <div class="tab-content" id="settings-tab" style="display: none;">
            <h2>Account Settings</h2>
            <form id="profile-settings">
                <div class="form-group">
                    <label for="username">Username</label>
                    <input type="text" id="username" value="<%= user.username %>" disabled>
                </div>
                
                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" value="<%= user.email || '' %>">
                </div>
                
                        <div class="form-group">
                            <label for="notification-preferences">Notification Preferences</label>
                            <div class="checkbox-group">
                                <label><input type="checkbox" checked> Class announcements</label>
                                <label><input type="checkbox" checked> Challenge updates</label>
                                <label><input type="checkbox"> Community updates</label>
                                <label><input type="checkbox"> Certification reminders</label>
                            </div>
                        </div>
                
                <div class="form-group">
                    <label for="privacy-settings">Privacy Settings</label>
                    <div class="radio-group">
                        <label><input type="radio" name="privacy" checked> Public profile</label>
                        <label><input type="radio" name="privacy"> Private profile</label>
                    </div>
                </div>
                
                <button type="submit" class="btn-primary">Save Changes</button>
            </form>
        </div>
    </main>

    <%- include('partials/footer'); %>
    
    <script src="/js/profile.js"></script>
</body>
</html>
