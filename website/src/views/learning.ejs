<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head'); %>
    <title>Interactive Learning | GLEECIN Academy</title>
    <link rel="stylesheet" href="/css/learning.css">
</head>
<body class="learning-page">
    <%- include('partials/header'); %>

    <main class="student-page learning-page__content">
        <section class="student-panel learning-hero">
            <div class="student-panel__header">
                <div>
                    <h1>Interactive Learning</h1>
                    <p>Answer quizzes and challenges with instant grading, saved progress, and downloadable certificates.</p>
                </div>
                <div class="learning-progress-summary">
                    <div class="summary-card">
                        <strong id="progress-total">0</strong>
                        <span>Total</span>
                    </div>
                    <div class="summary-card">
                        <strong id="progress-completed">0</strong>
                        <span>Completed</span>
                    </div>
                    <div class="summary-card">
                        <strong id="progress-accuracy">0%</strong>
                        <span>Accuracy</span>
                    </div>
                </div>
            </div>

            <div class="student-progress">
                <div class="student-progress__bar">
                    <span id="progress-bar-fill" style="width: 0%"></span>
                </div>
                <p id="progress-label">Progress 0%</p>
            </div>

            <div class="learning-controls">
                <label class="learning-control">
                    <span>Type</span>
                    <select id="type-filter" class="filter-select">
                        <option value="all">All types</option>
                        <option value="multiple_choice">Multiple choice</option>
                        <option value="true_false">True / False</option>
                        <option value="fill_blank">Fill in the blank</option>
                        <option value="debug">Debug</option>
                        <option value="prediction">Prediction</option>
                        <option value="challenge">Challenge</option>
                    </select>
                </label>

                <label class="learning-control">
                    <span>Search</span>
                    <input id="search-filter" type="text" class="search-input" placeholder="Search questions...">
                </label>

                <button id="refresh-learning" class="btn-secondary" type="button">Refresh</button>
            </div>
        </section>

        <section class="student-panel">
            <div id="learning-status" class="learning-status">Loading questions...</div>
            <div id="questions-container" class="student-list"></div>
        </section>

        <section class="student-panel">
            <div class="student-panel__header">
                <div>
                    <h2>Certificates</h2>
                    <p>Your earned certificates appear here after completion thresholds are met.</p>
                </div>
            </div>
            <div id="certificate-summary" class="student-empty-state">
                <p>No certificate has been issued yet.</p>
            </div>
            <div id="certificate-list" class="student-card-grid"></div>
        </section>
    </main>

    <%- include('partials/footer'); %>
    <script src="/js/learning.js"></script>
</body>
</html>
